---
import AnimatedSection from './AnimatedSection.tsx';
---

<section class="py-20 sm:py-28 bg-[#1a1a1a] overflow-hidden">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">

    <AnimatedSection animation="fadeUp" client:load>
      <div class="text-center mb-14">
        <p class="text-sm font-bold uppercase tracking-widest mb-3" style="color:#c8920a">The full flow</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white tracking-tight">
          Log → Review → Track
        </h2>
        <p class="mt-4 text-lg max-w-xl mx-auto" style="color:#9ca3af">
          Three screens. That's the whole experience.
        </p>
      </div>
    </AnimatedSection>

    <AnimatedSection animation="staggerUp" client:load>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 lg:gap-10 items-start">

        <!-- Screen 1: Input -->
        <div class="flex flex-col items-center gap-4">
          <div class="w-full max-w-[260px] mx-auto rounded-[2rem] overflow-hidden shadow-2xl" style="background:#0a0a0a;border:2px solid #2a2a2a">
            <!-- Status bar -->
            <div class="flex items-center justify-between px-4 pt-3 pb-1">
              <span class="text-[10px] font-semibold" style="color:#6b7280">9:41</span>
              <div class="flex items-center gap-1">
                <div class="rounded-sm border p-px" style="width:15px;height:8px;border-color:#6b7280">
                  <div class="h-full rounded-sm" style="width:65%;background:#6b7280"></div>
                </div>
              </div>
            </div>
            <!-- App header -->
            <div class="flex items-center justify-between px-4 pb-2">
              <span class="text-base font-black text-white">NomsAI</span>
              <div class="flex items-center gap-2.5">
                <!-- add-circle-outline -->
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>
                </svg>
                <!-- time-outline -->
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
              </div>
            </div>
            <!-- Input area content -->
            <div class="px-4 pt-2 pb-3">
              <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#6b7280">What did you eat?</p>
              <!-- Input examples list -->
              <div class="space-y-2 mb-5">
                {[
                  { text: '2 eggs, toast and butter', time: '08:30' },
                  { text: 'chicken breast 150g, rice 1 cup', time: '13:05' },
                  { text: 'Greek yoghurt 150g, blueberries', time: '16:00' },
                ].map(({ text, time }) => (
                  <div class="flex items-center justify-between rounded-xl px-3 py-2.5" style="background:#1a1a1a;border:1px solid #2a2a2a">
                    <p class="text-[10px] text-white flex-1 pr-2 leading-snug">{text}</p>
                    <p class="text-[9px] flex-shrink-0" style="color:#6b7280">{time}</p>
                  </div>
                ))}
              </div>
              <!-- Active input bar -->
              <div class="rounded-2xl flex items-center gap-2 px-3 py-2.5" style="background:#1a1a1a;border:1.5px solid #c8920a">
                <p class="flex-1 text-[11px] italic" style="color:#6b7280">oat milk latte, large…</p>
                <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-xl text-sm font-bold text-[#1c1714]" style="background:#c8920a">+</div>
              </div>
              <div class="flex items-center justify-between mt-2 px-1">
                <span class="text-[9px] font-bold" style="color:#c8920a">+ Add manually</span>
                <span class="text-[9px]" style="color:#6b7280">5 remaining today</span>
              </div>
            </div>
          </div>
          <div class="text-center">
            <div class="inline-flex items-center justify-center h-8 w-8 rounded-full text-sm font-black text-[#1c1714] mb-2" style="background:#c8920a">1</div>
            <p class="text-sm font-bold text-white">Type what you ate</p>
            <p class="text-xs mt-1" style="color:#9ca3af">Plain English — no menus</p>
          </div>
        </div>

        <!-- Screen 2: Review -->
        <div class="flex flex-col items-center gap-4 sm:mt-8">
          <div class="w-full max-w-[260px] mx-auto rounded-[2rem] overflow-hidden shadow-2xl" style="background:#0a0a0a;border:2px solid #2a2a2a">
            <!-- Status bar -->
            <div class="flex items-center justify-between px-4 pt-3 pb-1">
              <span class="text-[10px] font-semibold" style="color:#6b7280">9:41</span>
              <div class="flex items-center gap-1">
                <div class="rounded-sm border p-px" style="width:15px;height:8px;border-color:#6b7280">
                  <div class="h-full rounded-sm" style="width:65%;background:#6b7280"></div>
                </div>
              </div>
            </div>
            <!-- Review modal header -->
            <div class="flex items-center justify-between px-4 pt-2 pb-3">
              <div>
                <p class="text-base font-bold text-white">Review</p>
                <p class="text-[10px]" style="color:#9ca3af">Adjust anything NomsAI got wrong.</p>
              </div>
              <div class="flex h-7 w-7 items-center justify-center rounded-full text-sm" style="color:#9ca3af;background:#1a1a1a">✕</div>
            </div>
            <!-- Items -->
            <div class="px-4 space-y-2 pb-3">
              {[
                { name: 'Oat milk latte', kcal: '190', p: '6', c: '28', f: '6' },
                { name: 'Blueberry muffin', kcal: '420', p: '5', c: '62', f: '16' },
              ].map(({ name, kcal, p, c, f }) => (
                <div class="rounded-xl p-3" style="background:#1a1a1a;border:1px solid #2a2a2a">
                  <div class="flex items-center justify-between mb-2">
                    <p class="text-[11px] font-semibold text-white">{name}</p>
                    <div class="flex h-5 w-5 items-center justify-center rounded-full text-[9px]" style="color:#9ca3af;background:#2a2a2a">✕</div>
                  </div>
                  <div class="grid grid-cols-4 gap-1">
                    {[{l:'Cal',v:kcal,u:'kcal'},{l:'Pro',v:p,u:'g'},{l:'Carb',v:c,u:'g'},{l:'Fat',v:f,u:'g'}].map(({l,v,u}) => (
                      <div class="rounded-lg p-1.5 text-center" style="background:#2a2a2a">
                        <p class="text-[8px]" style="color:#6b7280">{l}</p>
                        <p class="text-[11px] font-bold text-white">{v}<span class="text-[7px] font-normal" style="color:#6b7280">{u}</span></p>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
              <!-- Total -->
              <div class="rounded-lg px-3 py-2" style="background:#0a0a0a;border:1px solid #2a2a2a">
                <p class="text-[8px] font-bold uppercase tracking-widest mb-0.5" style="color:#6b7280">TOTAL</p>
                <p class="text-sm font-bold text-white">610 kcal</p>
                <p class="text-[9px]" style="color:#9ca3af">11g protein · 90g carbs · 22g fat</p>
              </div>
            </div>
            <!-- Buttons -->
            <div class="flex gap-2 px-4 pb-4">
              <button class="flex-1 rounded-xl py-2.5 text-[11px] font-semibold text-white border" style="border-color:#2a2a2a;background:transparent">Discard</button>
              <button class="rounded-xl py-2.5 text-[11px] font-bold text-[#1c1714] px-4" style="background:#c8920a;flex:2">Confirm & Log</button>
            </div>
          </div>
          <div class="text-center">
            <div class="inline-flex items-center justify-center h-8 w-8 rounded-full text-sm font-black text-[#1c1714] mb-2" style="background:#c8920a">2</div>
            <p class="text-sm font-bold text-white">Review the estimates</p>
            <p class="text-xs mt-1" style="color:#9ca3af">Edit anything before saving</p>
          </div>
        </div>

        <!-- Screen 3: Dashboard -->
        <div class="flex flex-col items-center gap-4">
          <div class="w-full max-w-[260px] mx-auto rounded-[2rem] overflow-hidden shadow-2xl" style="background:#0a0a0a;border:2px solid #2a2a2a">
            <!-- Status bar -->
            <div class="flex items-center justify-between px-4 pt-3 pb-1">
              <span class="text-[10px] font-semibold" style="color:#6b7280">9:41</span>
              <div class="flex items-center gap-1">
                <div class="rounded-sm border p-px" style="width:15px;height:8px;border-color:#6b7280">
                  <div class="h-full rounded-sm" style="width:65%;background:#6b7280"></div>
                </div>
              </div>
            </div>
            <!-- Greeting + streak -->
            <div class="px-4 pt-1 pb-2 flex items-center justify-between">
              <p class="text-[10px]" style="color:#6b7280">☀️ Good morning</p>
              <div class="flex items-center gap-1 rounded-full px-2.5 py-0.5" style="background:#c8920a">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1c1714" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="8 21 12 21 16 21"/><line x1="12" y1="21" x2="12" y2="17"/><path d="M7.5 5H6a2 2 0 0 0-2 2v3c0 2.22 1.21 4.15 3 5.19"/><path d="M16.5 5H18a2 2 0 0 1 2 2v3c0 2.22-1.21 4.15-3 5.19"/><path d="M7.5 5a10 10 0 0 0 9 0"/><path d="M7.5 5C7.5 3 9 2 12 2s4.5 1 4.5 3"/>
                </svg>
                <span class="text-[9px] font-bold text-[#1c1714]">5 day streak</span>
              </div>
            </div>
            <!-- Calorie ring -->
            <div class="flex justify-center py-3">
              <div class="relative" style="width:100px;height:100px">
                <svg class="absolute inset-0 w-full h-full" style="transform:rotate(-90deg)" viewBox="0 0 100 100" aria-hidden="true">
                  <circle cx="50" cy="50" r="42" fill="none" stroke="#1a1a1a" stroke-width="8"/>
                  <circle cx="50" cy="50" r="42" fill="none" stroke="#c8920a" stroke-width="8" stroke-linecap="round" stroke-dasharray="264" stroke-dashoffset="68"/>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <span class="text-lg font-black text-white">1,218</span>
                  <span class="text-[9px] font-bold tracking-wider" style="color:#c8920a">KCAL</span>
                  <span class="text-[8px]" style="color:#6b7280">582 left</span>
                </div>
              </div>
            </div>
            <!-- Macro rings -->
            <div class="grid grid-cols-3 gap-1 px-5 pb-3">
              {[
                { label:'Protein', val:'48',  goal:'76g',  color:'#d97b5a', offset:'82' },
                { label:'Carbs',   val:'142', goal:'194g', color:'#7aaa78', offset:'44' },
                { label:'Fat',     val:'38',  goal:'51g',  color:'#b08898', offset:'48'  },
              ].map(({ label, val, goal, color, offset }) => (
                <div class="flex flex-col items-center gap-1">
                  <div class="relative" style="width:44px;height:44px">
                    <svg class="absolute inset-0 w-full h-full" style="transform:rotate(-90deg)" viewBox="0 0 44 44" aria-hidden="true">
                      <circle cx="22" cy="22" r="18" fill="none" stroke="#1a1a1a" stroke-width="4"/>
                      <circle cx="22" cy="22" r="18" fill="none" stroke={color} stroke-width="4" stroke-linecap="round"
                        stroke-dasharray="113" stroke-dashoffset={offset}/>
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center">
                      <span class="text-[10px] font-bold text-white">{val}</span>
                    </div>
                  </div>
                  <p class="text-[8px]" style="color:#9ca3af">{label}</p>
                  <p class="text-[8px]" style="color:#6b7280">{goal}</p>
                </div>
              ))}
            </div>
            <!-- Today's log preview -->
            <div class="px-4 pb-4">
              <p class="text-[8px] font-bold uppercase tracking-widest mb-2" style="color:#6b7280">TODAY'S LOG</p>
              {[
                { name: '2 eggs, toast and butter', kcal: '380', time: '08:30' },
                { name: 'Grilled chicken, rice, broccoli', kcal: '520', time: '13:05' },
                { name: 'Greek yoghurt, blueberries', kcal: '200', time: '16:00' },
                { name: 'Oat milk latte, blueberry muffin', kcal: '610', time: '09:41' },
              ].map(({ name, kcal, time }) => (
                <div class="flex items-center justify-between py-1.5 border-t" style="border-color:#1a1a1a">
                  <div class="flex-1 min-w-0 pr-2">
                    <p class="text-[10px] text-white leading-snug truncate">{name}</p>
                    <p class="text-[8px]" style="color:#6b7280">{time}</p>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <p class="text-[10px] font-bold text-white">{kcal}</p>
                    <p class="text-[8px]" style="color:#6b7280">kcal</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="text-center">
            <div class="inline-flex items-center justify-center h-8 w-8 rounded-full text-sm font-black text-[#1c1714] mb-2" style="background:#c8920a">3</div>
            <p class="text-sm font-bold text-white">See your daily picture</p>
            <p class="text-xs mt-1" style="color:#9ca3af">Rings, log, streak — all at once</p>
          </div>
        </div>

      </div>
    </AnimatedSection>

  </div>
</section>
