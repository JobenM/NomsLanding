---
---
<style>
  /* === 6s loop: shield draws → check draws → facts slide in → hold → reset === */

  /* Shield wrapper fades + scales in */
  .priv-shield-wrap {
    animation: priv-shield-in 6s ease-out infinite;
  }
  @keyframes priv-shield-in {
    0%, 3%   { opacity: 0; transform: scale(0.75); }
    14%, 90% { opacity: 1; transform: scale(1); }
    96%, 100%{ opacity: 0; transform: scale(1); }
  }

  /* Shield outline draws */
  .priv-shield-path {
    stroke-dasharray: 200;
    animation: priv-shield-draw 6s ease-out infinite;
  }
  @keyframes priv-shield-draw {
    0%, 3%   { stroke-dashoffset: 200; }
    20%, 100%{ stroke-dashoffset: 0; }
  }

  /* Check mark draws after shield */
  .priv-check {
    stroke-dasharray: 30;
    animation: priv-check-draw 6s ease-out infinite;
  }
  @keyframes priv-check-draw {
    0%, 18%  { stroke-dashoffset: 30; }
    30%, 100%{ stroke-dashoffset: 0; }
  }

  /* Fact cards slide in staggered */
  .priv-fact-1 {
    animation: priv-fact1 6s ease-out infinite;
  }
  @keyframes priv-fact1 {
    0%, 28%  { opacity: 0; transform: translateX(-12px); }
    38%, 90% { opacity: 1; transform: translateX(0); }
    96%, 100%{ opacity: 0; transform: translateX(0); }
  }

  .priv-fact-2 {
    animation: priv-fact2 6s ease-out infinite;
  }
  @keyframes priv-fact2 {
    0%, 33%  { opacity: 0; transform: translateX(-12px); }
    43%, 90% { opacity: 1; transform: translateX(0); }
    96%, 100%{ opacity: 0; transform: translateX(0); }
  }

  .priv-fact-3 {
    animation: priv-fact3 6s ease-out infinite;
  }
  @keyframes priv-fact3 {
    0%, 38%  { opacity: 0; transform: translateX(-12px); }
    48%, 90% { opacity: 1; transform: translateX(0); }
    96%, 100%{ opacity: 0; transform: translateX(0); }
  }

  .priv-fact-4 {
    animation: priv-fact4 6s ease-out infinite;
  }
  @keyframes priv-fact4 {
    0%, 43%  { opacity: 0; transform: translateX(-12px); }
    53%, 90% { opacity: 1; transform: translateX(0); }
    96%, 100%{ opacity: 0; transform: translateX(0); }
  }
</style>

<!-- Shield -->
<div class="flex justify-center py-4">
  <div class="priv-shield-wrap" style="opacity:0;transform:scale(0.75)">
    <div class="relative flex items-center justify-center" style="width:72px;height:72px">
      <div class="absolute inset-0 rounded-full blur-lg" style="background:rgba(200,146,10,0.2)"></div>
      <svg viewBox="0 0 56 64" fill="none" style="width:64px;height:64px;position:relative" aria-hidden="true">
        <path
          class="priv-shield-path"
          d="M28 4 L50 13 L50 32 C50 46 40 56 28 60 C16 56 6 46 6 32 L6 13 Z"
          stroke="#c8920a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
          fill="rgba(200,146,10,0.1)"
        />
        <path
          class="priv-check"
          d="M19 32 L25 38 L37 26"
          stroke="#c8920a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
          fill="none"
        />
      </svg>
    </div>
  </div>
</div>

<!-- Privacy facts -->
<div class="px-4 space-y-1.5 pb-3">
  {[
    { cls: 'priv-fact-1', text: 'No account required',        iconPath: 'M19 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2zm-7 4v4M8 11V7a4 4 0 0 1 8 0v4' },
    { cls: 'priv-fact-2', text: 'No server storage',          iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
    { cls: 'priv-fact-3', text: 'Zero data collection',       iconPath: 'M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24L1 1l22 22' },
    { cls: 'priv-fact-4', text: 'Uninstall = gone completely', iconPath: 'M3 6h18M8 6V4h8v2M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6' },
  ].map(({ cls, text, iconPath }) => (
    <div class:list={[cls, "flex items-center gap-3 rounded-xl px-3 py-2.5"]} style="background:var(--ph-surface);border:1px solid var(--ph-border);opacity:0;transform:translateX(-12px)">
      <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-lg" style="background:var(--ph-border)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c8920a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d={iconPath}/>
        </svg>
      </div>
      <p class="text-[11px] font-medium" style="color:var(--ph-fg)">{text}</p>
    </div>
  ))}
</div>
