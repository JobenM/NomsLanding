---
---
<style>
  /* === 18s loop ===
     Phase 1 (input):   0–4s    (0–22%)
     Phase 2 (loading): 3.5–6s  (19–33%)
     Phase 3 (card):    5.5s+   (30–89%), fast cascade
  ================================================================ */

  /* ── Phase 1: input ── */
  .mi-input-screen { animation: mi-input-show 18s ease-out infinite; }
  @keyframes mi-input-show {
    0%, 1%   { opacity: 1; }
    20%, 22% { opacity: 1; }
    25%, 100%{ opacity: 0; }
  }

  .mi-type-text {
    overflow: hidden; white-space: nowrap; max-width: 0;
    display: inline; vertical-align: middle;
    animation: mi-type 18s ease-out infinite;
  }
  @keyframes mi-type {
    0%, 4%   { max-width: 0; }
    18%, 22% { max-width: 160px; }
    25%, 100%{ max-width: 0; }
  }

  .mi-cursor {
    display: inline-block; width: 1.5px; height: 10px;
    background: #c8920a; vertical-align: middle; margin-left: 1px;
    animation: mi-blink 0.7s step-end infinite;
  }
  @keyframes mi-blink { 50% { opacity: 0; } }

  .mi-gen-btn { animation: mi-genbtn 18s ease-out infinite; }
  @keyframes mi-genbtn {
    0%, 16%  { opacity: 0; transform: translateY(5px); }
    20%, 22% { opacity: 1; transform: translateY(0); }
    25%, 100%{ opacity: 0; }
  }

  /* ── Phase 2: loading ── */
  .mi-loading { animation: mi-load-show 18s ease-out infinite; }
  @keyframes mi-load-show {
    0%, 20%  { opacity: 0; }
    23%, 30% { opacity: 1; }
    34%, 100%{ opacity: 0; }
  }

  .mi-shimmer {
    background: linear-gradient(90deg, var(--ph-border) 0%, var(--ph-surface) 45%, var(--ph-border) 100%);
    background-size: 200% 100%;
    animation: mi-shimmer-move 1.2s linear infinite;
    border-radius: 4px;
  }
  @keyframes mi-shimmer-move {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .mi-dot { animation: mi-dot-pulse 1.1s ease-in-out infinite; }
  .mi-dot:nth-child(2) { animation-delay: 0.18s; }
  .mi-dot:nth-child(3) { animation-delay: 0.36s; }
  @keyframes mi-dot-pulse {
    0%, 80%, 100% { opacity: 0.2; transform: scale(0.8); }
    40%           { opacity: 1;   transform: scale(1); }
  }

  /* ── Phase 3: fast cascade — each item ~0.5s after the last ── */

  .mi-card-header { animation: mi-ch 18s ease-out infinite; }
  @keyframes mi-ch {
    0%, 31%  { opacity: 0; transform: translateY(6px); }
    36%, 89% { opacity: 1; transform: translateY(0); }
    93%, 100%{ opacity: 0; }
  }

  .mi-macros { animation: mi-mac 18s ease-out infinite; }
  @keyframes mi-mac {
    0%, 38%  { opacity: 0; transform: translateY(4px); }
    42%, 89% { opacity: 1; transform: translateY(0); }
    93%, 100%{ opacity: 0; }
  }

  /* Ingredients — 3% apart = ~0.54s each */
  .mi-ing-label { animation: mi-il 18s ease-out infinite; }
  @keyframes mi-il { 0%, 43% { opacity: 0; } 46%, 89% { opacity: 1; } 93%, 100%{ opacity: 0; } }

  .mi-i1 { animation: mi-i1a 18s ease-out infinite; }
  @keyframes mi-i1a {
    0%, 44%  { opacity: 0; transform: translateX(-5px); }
    48%, 89% { opacity: 1; transform: translateX(0); }
    93%, 100%{ opacity: 0; }
  }
  .mi-i2 { animation: mi-i2a 18s ease-out infinite; }
  @keyframes mi-i2a {
    0%, 47%  { opacity: 0; transform: translateX(-5px); }
    51%, 89% { opacity: 1; transform: translateX(0); }
    93%, 100%{ opacity: 0; }
  }
  .mi-i3 { animation: mi-i3a 18s ease-out infinite; }
  @keyframes mi-i3a {
    0%, 50%  { opacity: 0; transform: translateX(-5px); }
    54%, 89% { opacity: 1; transform: translateX(0); }
    93%, 100%{ opacity: 0; }
  }

  .mi-tick1 { animation: mi-t1a 18s ease-out infinite; }
  @keyframes mi-t1a { 0%, 48% { opacity: 0; transform: scale(0.3); } 52%, 89% { opacity: 1; transform: scale(1); } 93%, 100%{ opacity: 0; } }
  .mi-tick2 { animation: mi-t2a 18s ease-out infinite; }
  @keyframes mi-t2a { 0%, 51% { opacity: 0; transform: scale(0.3); } 55%, 89% { opacity: 1; transform: scale(1); } 93%, 100%{ opacity: 0; } }

  /* Method — 4% apart = ~0.72s each */
  .mi-method-label { animation: mi-ml 18s ease-out infinite; }
  @keyframes mi-ml { 0%, 55% { opacity: 0; } 58%, 89% { opacity: 1; } 93%, 100%{ opacity: 0; } }

  .mi-s1 { animation: mi-step1 18s ease-out infinite; }
  @keyframes mi-step1 {
    0%, 57%  { opacity: 0; transform: translateY(4px); }
    61%, 89% { opacity: 1; transform: translateY(0); }
    93%, 100%{ opacity: 0; }
  }
  .mi-s2 { animation: mi-step2 18s ease-out infinite; }
  @keyframes mi-step2 {
    0%, 63%  { opacity: 0; transform: translateY(4px); }
    67%, 89% { opacity: 1; transform: translateY(0); }
    93%, 100%{ opacity: 0; }
  }
  .mi-s3 { animation: mi-step3 18s ease-out infinite; }
  @keyframes mi-step3 {
    0%, 69%  { opacity: 0; transform: translateY(4px); }
    73%, 89% { opacity: 1; transform: translateY(0); }
    93%, 100%{ opacity: 0; }
  }
</style>

<div class="relative px-3 pt-1" style="min-height:460px">

  <!-- ══ PHASE 1: Input ══ -->
  <div class="mi-input-screen absolute inset-x-3 top-0">
    <div class="flex items-center gap-2 mb-3">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ph-muted)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      <span class="text-[11px] font-black" style="color:var(--ph-fg)">Meal Ideas</span>
    </div>
    <p class="text-[9px] mb-2" style="color:var(--ph-muted)">What ingredient do you want to use?</p>
    <div class="rounded-xl px-3 py-3 mb-5 flex items-center" style="background:var(--ph-surface);border:1.5px solid #c8920a;min-height:42px">
      <span class="mi-type-text text-[10px]" style="color:var(--ph-fg)">chicken and broccoli</span>
      <span class="mi-cursor"></span>
    </div>
    <div class="mi-gen-btn flex items-center justify-center gap-2 rounded-2xl py-3" style="background:#c8920a;opacity:0">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#1c1714" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <span class="text-[11px] font-bold text-[#1c1714]">Generate Ideas</span>
    </div>
  </div>

  <!-- ══ PHASE 2: Loading ══ -->
  <div class="mi-loading absolute inset-x-3 top-0" style="opacity:0">
    <div class="flex items-center gap-2 mb-4">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ph-muted)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      <span class="text-[11px] font-black" style="color:var(--ph-fg)">Meal Ideas</span>
    </div>
    <div class="flex items-center gap-2 mb-4">
      <span class="text-[8px] font-semibold" style="color:#c8920a">Generating your recipe</span>
      <div class="flex gap-1">
        <span class="mi-dot w-1 h-1 rounded-full inline-block" style="background:#c8920a"></span>
        <span class="mi-dot w-1 h-1 rounded-full inline-block" style="background:#c8920a"></span>
        <span class="mi-dot w-1 h-1 rounded-full inline-block" style="background:#c8920a"></span>
      </div>
    </div>
    <div class="rounded-2xl p-3 mb-3" style="background:var(--ph-surface);border:1px solid var(--ph-border)">
      <div class="flex items-start gap-2 mb-3">
        <div class="mi-shimmer flex-shrink-0" style="width:32px;height:32px;border-radius:8px"></div>
        <div class="flex-1">
          <div class="mi-shimmer h-2.5 rounded mb-2" style="width:75%"></div>
          <div class="mi-shimmer h-2 rounded" style="width:45%"></div>
        </div>
      </div>
      <div class="mi-shimmer h-2 rounded mb-1.5" style="width:90%"></div>
      <div class="mi-shimmer h-2 rounded" style="width:60%"></div>
    </div>
    <div class="rounded-xl p-2.5 grid grid-cols-4 gap-2" style="background:var(--ph-surface);border:1px solid var(--ph-border)">
      {[70,55,50,50].map((w) => (
        <div class="flex flex-col items-center gap-1">
          <div class="mi-shimmer h-3 rounded" style={`width:${w}%`}></div>
          <div class="mi-shimmer h-1.5 rounded" style="width:80%"></div>
        </div>
      ))}
    </div>
  </div>

  <!-- ══ PHASE 3: Card header ══ -->
  <div class="mi-card-header absolute inset-x-3 top-0" style="opacity:0">
    <div class="flex items-center gap-2 mb-2">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ph-muted)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      <span class="text-[11px] font-black" style="color:var(--ph-fg)">Meal Ideas</span>
    </div>
    <div class="rounded-2xl p-3" style="background:var(--ph-surface);border:1px solid var(--ph-border)">
      <div class="flex items-start justify-between gap-2 mb-2">
        <div class="flex items-start gap-2">
          <span style="font-size:22px;line-height:1;flex-shrink:0">🥦</span>
          <div>
            <p class="text-[11px] font-black leading-tight" style="color:var(--ph-fg)">Chicken &amp; Broccoli Bake</p>
            <p class="text-[8px] mt-0.5" style="color:var(--ph-muted)">Comforting weeknight one-dish bake.</p>
          </div>
        </div>
        <span class="flex-shrink-0 rounded-full px-2 py-0.5 text-[7px] font-bold" style="background:#1a3a1a;color:#4caf50">Easy</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-[8px]" style="color:var(--ph-muted)">⏱ 45 min</span>
        <span class="text-[8px] font-bold" style="color:var(--ph-fg)">650 kcal</span>
        <span class="text-[8px]" style="color:var(--ph-muted)">4 servings</span>
      </div>
    </div>
  </div>

  <!-- Macros -->
  <div class="mi-macros absolute inset-x-3" style="top:116px;opacity:0">
    <div class="rounded-xl px-2 py-2 grid grid-cols-4 gap-1" style="background:#111">
      {[{v:'650',l:'Calories'},{v:'45g',l:'Protein'},{v:'40g',l:'Carbs'},{v:'35g',l:'Fat'}].map(({v,l}) => (
        <div class="flex flex-col items-center">
          <span class="text-[11px] font-black" style="color:var(--ph-fg)">{v}</span>
          <span class="text-[6.5px]" style="color:var(--ph-muted)">{l}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Ingredients label -->
  <div class="mi-ing-label absolute inset-x-3" style="top:162px;opacity:0">
    <p class="text-[7px] font-bold uppercase tracking-widest mb-0.5" style="color:var(--ph-muted)">Ingredients (4 servings)</p>
  </div>

  <!-- Ingredient rows -->
  {[
    { name:'Chicken breast', amount:'600g', ticked:true,  top:174, cls:'mi-i1', tickCls:'mi-tick1' },
    { name:'Broccoli',       amount:'500g', ticked:true,  top:196, cls:'mi-i2', tickCls:'mi-tick2' },
    { name:'Potatoes',       amount:'800g', ticked:false, top:218, cls:'mi-i3', tickCls:'' },
  ].map(({ name, amount, ticked, top, cls, tickCls }) => (
    <div class={`${cls} absolute inset-x-3 flex items-center justify-between py-1`} style={`top:${top}px;opacity:0;border-bottom:1px solid var(--ph-border)`}>
      <div class="flex items-center gap-2">
        {ticked ? (
          <div class={`${tickCls} flex items-center justify-center rounded-full flex-shrink-0`} style="width:14px;height:14px;background:#1a3a1a;opacity:0">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
        ) : (
          <div class="flex items-center justify-center rounded-full flex-shrink-0" style="width:14px;height:14px;border:1.5px solid var(--ph-border)">
            <svg width="7" height="7" viewBox="0 0 24 24" fill="none" stroke="var(--ph-muted)" stroke-width="3" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </div>
        )}
        <span class="text-[9px] font-medium" style={`color:${ticked ? 'var(--ph-muted)' : 'var(--ph-fg)'};${ticked ? 'text-decoration:line-through' : ''}`}>{name}</span>
      </div>
      <span class="text-[8px]" style="color:var(--ph-muted)">{amount}</span>
    </div>
  ))}

  <!-- Method label -->
  <div class="mi-method-label absolute inset-x-3" style="top:246px;opacity:0">
    <p class="text-[7px] font-bold uppercase tracking-widest" style="color:var(--ph-muted)">Method</p>
  </div>

  <!-- Method steps -->
  {[
    { n:1, text:'Preheat oven to 200°C (180°C fan).', top:260, cls:'mi-s1' },
    { n:2, text:'Slice potatoes thinly and layer in a baking dish.', top:289, cls:'mi-s2' },
    { n:3, text:'Add chicken and broccoli, season generously.', top:320, cls:'mi-s3' },
  ].map(({ n, text, top, cls }) => (
    <div class={`${cls} absolute inset-x-3 flex items-start gap-2`} style={`top:${top}px;opacity:0`}>
      <div class="flex items-center justify-center rounded-full flex-shrink-0 mt-0.5" style="width:16px;height:16px;background:#c8920a">
        <span class="text-[7px] font-black text-[#1c1714]">{n}</span>
      </div>
      <p class="text-[8.5px] leading-tight flex-1" style="color:var(--ph-fg)">{text}</p>
    </div>
  ))}

</div>
