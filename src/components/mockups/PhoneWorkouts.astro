---
---
<style>
  /* === 5s loop: workout entry + burned ring fills → net row → hold → reset === */

  .work-entry {
    animation: work-entry-in 5s ease-out infinite;
  }
  @keyframes work-entry-in {
    0%, 8%   { opacity: 0; transform: translateY(-6px); max-height: 0; overflow: hidden; margin-bottom: 0; }
    16%      { max-height: 60px; overflow: visible; }
    20%, 82% { opacity: 1; transform: translateY(0); max-height: 60px; }
    92%, 100%{ opacity: 0; max-height: 60px; }
  }

  .work-burned-ring {
    stroke-dasharray: 175;
    animation: work-burn 5s ease-out infinite;
  }
  @keyframes work-burn {
    0%, 12%  { stroke-dashoffset: 175; }
    38%, 100%{ stroke-dashoffset: 55; }
  }

  .work-eaten-ring {
    stroke-dasharray: 283;
    animation: work-eat 5s ease-out infinite;
  }
  @keyframes work-eat {
    0%, 5%   { stroke-dashoffset: 283; }
    30%, 100%{ stroke-dashoffset: 150; }
  }

  .work-kcal {
    animation: work-kcal-appear 5s ease-out infinite;
  }
  @keyframes work-kcal-appear {
    0%, 5%   { opacity: 0; }
    20%, 82% { opacity: 1; }
    92%, 100%{ opacity: 0; }
  }

  .work-burned-row {
    animation: work-stats-in 5s ease-out infinite;
  }
  @keyframes work-stats-in {
    0%, 25%  { opacity: 0; transform: translateY(4px); }
    38%, 82% { opacity: 1; transform: translateY(0); }
    92%, 100%{ opacity: 0; }
  }
</style>

<!-- Date strip -->
<div class="flex gap-1.5 px-3 pb-2 overflow-hidden">
  {['Tue 24', 'Wed 25', 'Thu 26', 'Fri 27'].map((d) => (
    <div class="flex-shrink-0 flex items-center rounded-full px-2 py-0.5" style="background:var(--ph-surface);border:1px solid var(--ph-border)">
      <span class="text-[8px] font-medium" style="color:var(--ph-muted)">{d}</span>
    </div>
  ))}
  <div class="flex-shrink-0 flex items-center rounded-full px-2 py-0.5 font-bold text-[8px]" style="background:#c8920a;color:#1c1714">Today</div>
</div>

<div class="px-4 pb-2"><p class="text-[9px]" style="color:var(--ph-muted)">💪 Good morning</p></div>

<!-- Ring + Macros — ring has eaten (outer gold) + burned (inner blue) -->
<div class="flex items-center justify-center px-3 pb-1 gap-4">
  <div class="relative flex-shrink-0" style="width:108px;height:108px">
    <svg class="absolute inset-0" width="108" height="108" viewBox="0 0 108 108" style="transform:rotate(-90deg)" aria-hidden="true">
      <!-- Outer track + eaten ring (gold) -->
      <circle cx="54" cy="54" r="45" fill="none" stroke="var(--ph-border)" stroke-width="9"/>
      <circle class="work-eaten-ring" cx="54" cy="54" r="45" fill="none" stroke="#c8920a" stroke-width="9" stroke-linecap="round" stroke-dashoffset="283"/>
      <!-- Inner track + burned ring (blue) -->
      <circle cx="54" cy="54" r="34" fill="none" stroke="#1e2a35" stroke-width="7"/>
      <circle class="work-burned-ring" cx="54" cy="54" r="34" fill="none" stroke="#6b9fd4" stroke-width="7" stroke-linecap="round" stroke-dashoffset="175"/>
    </svg>
    <div class="absolute inset-0 flex flex-col items-center justify-center">
      <span class="work-kcal text-lg font-black" style="color:var(--ph-fg);opacity:0">405</span>
      <span class="text-[8px] font-bold" style="color:#c8920a">KCAL</span>
    </div>
  </div>
  <div class="flex flex-col gap-2.5">
    {[
      { label:'Protein', val:'20g', left:'56g left',  color:'#60a5fa', fill:26 },
      { label:'Carbs',   val:'33g', left:'121g left', color:'#fb923c', fill:21 },
      { label:'Fat',     val:'21g', left:'23g left',  color:'#cb9ad8', fill:48 },
    ].map(({ label, val, left, color, fill }) => (
      <div class="flex items-center gap-2">
        <div class="relative overflow-hidden flex-shrink-0" style={`width:12px;height:30px;border-radius:6px;border:1.5px solid ${color}40;background:${color}12`}>
          <div class="absolute bottom-0 left-0 right-0" style={`height:${fill}%;background:${color}cc`}></div>
        </div>
        <div>
          <p class="text-[7px]" style="color:var(--ph-muted)">{label}</p>
          <p class="text-[9px] font-semibold" style="color:var(--ph-fg)">{val}</p>
          <p class="text-[7px]" style="color:var(--ph-muted)">{left}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<!-- Burned row -->
<div class="work-burned-row flex items-center gap-1.5 px-4 pb-2" style="opacity:0">
  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#6b9fd4" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
    <path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 11-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 3z"/>
  </svg>
  <span class="text-[9px] font-semibold" style="color:#6b9fd4">213 kcal burned</span>
</div>

<!-- TODAY'S LOG -->
<div class="px-3 pb-1">
  <p class="text-[7px] font-bold uppercase tracking-widest mb-1.5" style="color:var(--ph-muted)">TODAY'S LOG</p>

  <!-- Workout entry (animated) -->
  <div class="work-entry rounded-xl p-2 mb-1.5" style="background:var(--ph-surface);border-left:2.5px solid #6b9fd4;border-top:1px solid var(--ph-border);border-right:1px solid var(--ph-border);border-bottom:1px solid var(--ph-border);opacity:0;max-height:0;overflow:hidden;margin-bottom:0">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-1.5">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6b9fd4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="4" r="2"/>
          <path d="M15.89 8.11L13 13l-2 4H9m0 0l-2-4 3-4.89M11 17l1 4M9 13l-3 1.5"/>
        </svg>
        <div>
          <p class="text-[9px] font-semibold" style="color:var(--ph-fg)">Run</p>
          <p class="text-[7px]" style="color:var(--ph-muted)">07:30 · 30 min</p>
        </div>
      </div>
      <div class="text-right">
        <p class="text-[10px] font-bold" style="color:#6b9fd4">213</p>
        <p class="text-[7px]" style="color:#6b9fd4">burned</p>
      </div>
    </div>
  </div>

  <!-- Food entry (static) -->
  <div class="rounded-xl px-2.5 py-2" style="background:var(--ph-surface);border:1px solid var(--ph-border)">
    <div class="flex items-start justify-between gap-1.5">
      <p class="text-[9px] font-semibold flex-1 leading-tight" style="color:var(--ph-fg)">Eggs (114g) · White toast (64g) · Butter (10g)</p>
      <div class="flex-shrink-0 text-right">
        <p class="text-[10px] font-bold" style="color:var(--ph-fg)">405</p>
        <p class="text-[7px]" style="color:var(--ph-muted)">kcal</p>
      </div>
    </div>
    <div class="flex items-center gap-1.5 mt-1">
      <p class="text-[7px]" style="color:var(--ph-muted)">08:30</p>
      <span class="rounded-full px-1.5 py-0.5 text-[7px] font-medium" style="background:var(--ph-border);color:#d97b5a">+20g</span>
      <span class="rounded-full px-1.5 py-0.5 text-[7px] font-medium" style="background:var(--ph-border);color:#7aaa78">+33g</span>
      <span class="rounded-full px-1.5 py-0.5 text-[7px] font-medium" style="background:var(--ph-border);color:#b08898">+21g</span>
    </div>
  </div>
</div>

<div class="flex-1"></div>
<!-- Input bar — correct two-part layout with mic inside + separate square submit -->
<div class="px-3 pt-2 pb-1">
  <div class="flex items-center gap-2">
    <!-- Main input area with mic inside -->
    <div class="relative flex-1 rounded-xl px-3 py-3 pr-10" style="background:var(--ph-surface);border:1px solid var(--ph-border);min-height:46px">
      <p class="text-[9px] italic" style="color:var(--ph-placeholder)">Log food or workout…</p>
      <!-- Mic inside input -->
      <div class="absolute right-2 top-1/2 -translate-y-1/2 flex h-7 w-7 items-center justify-center rounded-full">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="color:var(--ph-muted)" aria-hidden="true">
          <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
        </svg>
      </div>
    </div>
    <!-- Submit button (separate square, mustard) -->
    <div class="flex h-[38px] w-[38px] flex-shrink-0 items-center justify-center rounded-xl font-black text-base text-[#1c1714]" style="background:#c8920a">+</div>
  </div>
</div>
<div class="flex items-center justify-between px-4 pb-2">
  <span class="text-[9px] font-semibold" style="color:#c8920a">⊕ Add manually</span>
  <span class="text-[9px]" style="color:var(--ph-muted)">⚡ Unlimited</span>
</div>
