---
import AnimatedSection from './AnimatedSection.tsx';

const steps = [
  {
    number: '01',
    // Ionicons chatbubble-outline / message-outline
    iconPath: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
    title: 'Type what you ate',
    description: 'Just describe your meal in plain English. "Bowl of ramen with egg" or "protein bar and a banana" — no barcode scanning, no searching a database.',
    example: '"Grilled salmon, steamed broccoli, and brown rice"',
  },
  {
    number: '02',
    // Ionicons flash-outline
    iconPath: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
    title: 'AI estimates macros instantly',
    description: 'Google Gemini parses your description and returns calories, protein, carbs, and fat in under a second. Review and adjust anything before saving.',
    example: '→ 520 kcal · 42g protein · 48g carbs · 12g fat',
  },
  {
    number: '03',
    // Ionicons pie-chart-outline
    iconPaths: ['M21.21 15.89A10 10 0 1 1 8 2.83', 'M22 12A10 10 0 0 0 12 2v10z'],
    title: 'Review your daily nutrition',
    description: 'See your daily macro totals with the calorie ring, three macro rings (protein, carbs, fat), and your log — all on one screen. Spot patterns, make smarter choices.',
    example: 'Daily: 1,840 kcal · 135g P · 210g C · 58g F',
  },
];
---

<section id="how-it-works" class="py-20 sm:py-28 bg-[#edeae5] dark:bg-[#0a0a0a]">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">

    <AnimatedSection animation="fadeUp" client:load>
      <div class="text-center mb-16">
        <p class="text-sm font-bold uppercase tracking-widest mb-3" style="color:#c8920a">Simple by design</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-[#1c1714] dark:text-white tracking-tight">
          Three steps. That's it.
        </h2>
        <p class="mt-4 text-lg max-w-2xl mx-auto" style="color:#6b6560">
          No barcode scanning. No database searching. No account setup. The fastest AI food diary you'll ever use.
        </p>
      </div>
    </AnimatedSection>

    <AnimatedSection animation="staggerUp" client:load>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {steps.map(({ number, iconPath, iconPaths, title, description, example }) => (
          <div class="relative flex flex-col rounded-2xl border p-8 shadow-sm transition-all duration-300 hover:shadow-md hover:-translate-y-0.5 bg-white dark:bg-[#1a1a1a]"
            style="border-color:#d4ccc4">

            <div class="flex items-center gap-4 mb-6">
              <!-- Mustard icon background -->
              <div class="relative flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-2xl shadow-lg"
                style="background:#c8920a;box-shadow:0 4px 12px rgba(200,146,10,0.3)">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {iconPath && <path d={iconPath}/>}
                  {iconPaths && iconPaths.map((p) => <path d={p}/>)}
                </svg>
                <span class="absolute -top-2 -right-2 flex h-5 w-5 items-center justify-center rounded-full text-[10px] font-black border-2 border-white"
                  style="background:#c8920a;color:white">
                  {number.replace('0', '')}
                </span>
              </div>
              <span class="text-5xl font-black select-none" style="color:#d4ccc4">{number}</span>
            </div>

            <h3 class="text-xl font-bold text-[#1c1714] mb-3">{title}</h3>
            <p class="leading-relaxed mb-6 flex-1 text-sm" style="color:#6b6560">{description}</p>

            <div class="rounded-xl px-4 py-3 border bg-[#f4f2ef] dark:bg-[#0a0a0a]" style="border-color:#d4ccc4">
              <p class="text-sm font-mono" style="color:#c8920a">{example}</p>
            </div>
          </div>
        ))}
      </div>
    </AnimatedSection>

    <AnimatedSection animation="fadeUp" delay={0.2} client:load>
      <div class="mt-14 text-center">
        <a href="/how-it-works" class="inline-flex items-center gap-2 font-semibold hover:gap-3 transition-all duration-200" style="color:#c8920a">
          See the full walkthrough
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </AnimatedSection>

  </div>
</section>
