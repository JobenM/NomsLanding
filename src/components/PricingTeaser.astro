---
import AnimatedSection from './AnimatedSection.tsx';
---

<section class="py-16 sm:py-20 bg-[#f4f2ef] dark:bg-[#0a0a0a] border-y border-[#d4ccc4] dark:border-[#2a2a2a]">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
    <AnimatedSection animation="fadeUp" client:load>
      <p class="text-sm font-bold uppercase tracking-widest mb-4" style="color:#c8920a">Pricing</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-4 text-[#1c1714] dark:text-white">
        Premium tracking. Indie pricing.
      </h2>
      <p class="text-lg text-[#6b6560] dark:text-[#9ca3af] mb-8 max-w-xl mx-auto">
        NomsAI is free for up to 5 logs a day. Need unlimited? Unlock everything for just <strong id="teaser-price" data-gbp="£2.50/mo" data-usd="$3.33/mo" class="text-[#1c1714] dark:text-white font-semibold">£2.50/mo</strong>.
      </p>
      <a
        href="/pricing"
        class="inline-flex items-center gap-2 rounded-xl px-6 py-3.5 text-sm font-bold transition-all duration-200 hover:opacity-90 active:scale-[0.98]"
        style="background:#c8920a;color:#1c1714"
      >
        View full pricing
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </AnimatedSection>
  </div>
</section>

<script>
  function applyTeaserPricing() {
    const isUS = /^en-US|^en-CA/.test(navigator.language);
    if (!isUS) return;
    const el = document.getElementById('teaser-price');
    if (el) el.textContent = el.dataset.usd ?? el.textContent;
  }
  applyTeaserPricing();
  document.addEventListener('astro:after-swap', applyTeaserPricing);
</script>
