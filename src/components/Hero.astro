---
import AnimatedSection from './AnimatedSection.tsx';
---

<section class="relative overflow-hidden bg-[#f4f2ef] dark:bg-[#0a0a0a] pt-16 pb-24 sm:pt-24 sm:pb-32">
  <!-- Subtle bg texture -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-32 w-[500px] h-[500px] rounded-full" style="background:radial-gradient(circle,rgba(200,146,10,0.12) 0%,transparent 70%)"></div>
    <div class="absolute -bottom-20 -left-32 w-[400px] h-[400px] rounded-full" style="background:radial-gradient(circle,rgba(200,146,10,0.08) 0%,transparent 70%)"></div>
    <div class="absolute inset-0 bg-hero-pattern opacity-25"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text -->
      <div class="text-center lg:text-left">

        <!-- App icon + wordmark — matches AppLogo.tsx exactly -->
        <AnimatedSection animation="fadeIn" delay={0} client:load>
          <div class="inline-flex items-center gap-3 mb-8">
            <!-- Mustard rounded square, #c8920a, 🍽️ emoji -->
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl text-2xl shadow-lg" style="background-color:#c8920a;box-shadow:0 4px 16px rgba(200,146,10,0.35)">
              🍽️
            </div>
            <span class="text-2xl font-black tracking-tight text-[#1c1714] dark:text-white">NomsAI</span>
          </div>
        </AnimatedSection>

        <!-- Headline -->
        <AnimatedSection animation="fadeUp" delay={0.1} client:load>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-[#1c1714] dark:text-white leading-[1.05] mb-4">
            Type it. Say it.
            <br />
            <span style="color:#c8920a">AI handles the rest.</span>
          </h1>
        </AnimatedSection>

        <!-- Sub -->
        <AnimatedSection animation="fadeUp" delay={0.2} client:load>
          <p class="text-lg text-[#6b6560] dark:text-[#9ca3af] leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
            The <strong class="text-[#1c1714] dark:text-white font-semibold">AI calorie tracker</strong> that respects your time and your privacy.
            Type or speak any meal — AI looks up real nutrition data, splits multi-item entries, and keeps everything on your device.
            No login. No account. No nonsense.
          </p>
        </AnimatedSection>

        <!-- Feature rows — matches onboarding screen exactly:
             Ionicons flash-outline / pie-chart-outline / shield-checkmark-outline -->
        <AnimatedSection animation="fadeUp" delay={0.25} client:load>
          <div class="flex flex-col gap-3 mb-10 max-w-sm mx-auto lg:mx-0">

            <!-- Type or speak -->
            <div class="flex items-center gap-3 rounded-2xl bg-[#edeae5] dark:bg-[#1a1a1a] border border-[#d4ccc4] dark:border-[#2a2a2a] px-4 py-3">
              <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#1c1714] dark:bg-[#2a2a2a]">
                <!-- mic icon -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                  <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                  <line x1="12" y1="19" x2="12" y2="23"/>
                  <line x1="8" y1="23" x2="16" y2="23"/>
                </svg>
              </div>
              <div class="text-left">
                <p class="text-sm font-bold text-[#1c1714] dark:text-white">Type it or say it</p>
                <p class="text-xs text-[#6b6560] dark:text-[#9ca3af]">Voice or text — your choice</p>
              </div>
            </div>

            <!-- Full macros — pie-chart-outline icon -->
            <div class="flex items-center gap-3 rounded-2xl bg-[#edeae5] dark:bg-[#1a1a1a] border border-[#d4ccc4] dark:border-[#2a2a2a] px-4 py-3">
              <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#1c1714] dark:bg-[#2a2a2a]">
                <!-- Ionicons pie-chart-outline -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21.21 15.89A10 10 0 1 1 8 2.83"/>
                  <path d="M22 12A10 10 0 0 0 12 2v10z"/>
                </svg>
              </div>
              <div class="text-left">
                <p class="text-sm font-bold text-[#1c1714] dark:text-white">Full macros</p>
                <p class="text-xs text-[#6b6560] dark:text-[#9ca3af]">Calories, protein, carbs & fat</p>
              </div>
            </div>

            <!-- No account needed — shield-checkmark-outline icon -->
            <div class="flex items-center gap-3 rounded-2xl bg-[#edeae5] dark:bg-[#1a1a1a] border border-[#d4ccc4] dark:border-[#2a2a2a] px-4 py-3">
              <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#1c1714] dark:bg-[#2a2a2a]">
                <!-- Ionicons shield-checkmark-outline -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
              </div>
              <div class="text-left">
                <p class="text-sm font-bold text-[#1c1714] dark:text-white">No account needed</p>
                <p class="text-xs text-[#6b6560] dark:text-[#9ca3af]">Everything stays on your phone</p>
              </div>
            </div>
          </div>
        </AnimatedSection>

        <!-- CTAs -->
        <AnimatedSection animation="fadeUp" delay={0.35} client:load>
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a
              href="#download"
              class="inline-flex items-center gap-3 rounded-2xl px-7 py-4 text-base font-bold text-[#1c1714] shadow-lg hover:scale-[1.03] active:scale-[0.98] transition-all duration-200"
              style="background-color:#c8920a;box-shadow:0 4px 20px rgba(200,146,10,0.3)"
            >
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              App Store
            </a>
            <a
              href="#download"
              class="inline-flex items-center gap-3 rounded-2xl border-2 bg-white dark:bg-[#1a1a1a] px-7 py-4 text-base font-bold text-[#1c1714] dark:text-white hover:scale-[1.03] active:scale-[0.98] transition-all duration-200"
              style="border-color:#d4ccc4"
            >
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" style="color:#c8920a" aria-hidden="true">
                <path d="M3.18 23.76c.3.17.66.19.99.08l12.45-7.2-2.68-2.68-10.76 9.8zm-1.63-20.4C1.21 3.77 1 4.24 1 4.87v14.26c0 .63.21 1.1.55 1.42l.08.07 7.99-7.99v-.19L1.63 4.29l-.08.07zM20.96 10.16l-2.67-1.54-3 2.99 3 2.99 2.69-1.55c.76-.44.76-1.45-.02-1.89zM4.17.24L16.62 7.44 13.94 10.12 3.18.32c.33-.11.7-.09.99.08v-.16z"/>
              </svg>
              Google Play
            </a>
          </div>
        </AnimatedSection>

      </div>

      <!-- Right: Phone mockup — matches real app UI exactly -->
      <AnimatedSection animation="slideLeft" delay={0.2} client:load>
        <div class="relative mx-auto w-[280px] sm:w-[320px]">
          <!-- Glow -->
          <div class="absolute inset-0 rounded-[3rem] blur-2xl scale-110 pointer-events-none" style="background:radial-gradient(circle,rgba(200,146,10,0.2) 0%,transparent 70%)"></div>

          <!-- Phone frame — dark bezel in light mode, bright silver in dark mode -->
          <div class="relative rounded-[3rem] p-[4px] shadow-2xl bg-[#1a1a1a] dark:bg-[#ddd8d0]" style="box-shadow:0 32px 64px rgba(0,0,0,0.4)">
            <div class="rounded-[2.8rem] overflow-hidden flex flex-col" style="background:var(--ph-bg);height:600px">

              <!-- Status bar -->
              <div class="flex items-center justify-between px-5 pt-3 pb-1">
                <span class="text-[11px] font-semibold" style="color:var(--ph-muted)">9:41</span>
                <div class="flex items-center gap-1.5">
                  <svg width="15" height="11" viewBox="0 0 15 11" fill="none" style="color:var(--ph-muted)" aria-hidden="true">
                    <rect x="0" y="3" width="3" height="8" rx="0.5" fill="currentColor"/>
                    <rect x="4" y="2" width="3" height="9" rx="0.5" fill="currentColor"/>
                    <rect x="8" y="0.5" width="3" height="10.5" rx="0.5" fill="currentColor"/>
                    <rect x="12" y="0" width="3" height="11" rx="0.5" fill="currentColor" opacity="0.4"/>
                  </svg>
                  <div class="flex items-center gap-0.5">
                    <div class="rounded-sm border p-px" style="width:18px;height:10px;border-color:var(--ph-muted)">
                      <div class="h-full rounded-sm" style="width:65%;background:var(--ph-muted)"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- App header -->
              <div class="flex items-center justify-between px-4 pt-1 pb-2">
                <span class="text-lg font-black tracking-tight" style="color:var(--ph-fg)">NomsAI</span>
                <div class="flex items-center gap-2.5" style="color:var(--ph-muted)">
                  <!-- barbell-outline -->
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M6 5v14M18 5v14M2 9h4M18 9h4M2 15h4M18 15h4M6 9h12M6 15h12"/>
                  </svg>
                  <!-- time-outline -->
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                  <!-- analytics-outline: bar chart -->
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/>
                  </svg>
                  <!-- book-outline -->
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                  </svg>
                  <!-- settings-outline -->
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                  </svg>
                </div>
              </div>

              <!-- Date strip -->
              <div class="flex gap-1.5 px-3 pb-2 overflow-hidden">
                {['Wed 15', 'Thu 16', 'Fri 17', 'Sat 18'].map((d) => (
                  <div class="flex-shrink-0 rounded-full px-2.5 py-1" style="background:var(--ph-surface);border:1px solid var(--ph-border)">
                    <span class="text-[9px] font-medium" style="color:var(--ph-muted)">{d}</span>
                  </div>
                ))}
                <div class="flex-shrink-0 rounded-full px-2.5 py-1 font-bold text-[9px]" style="background:#c8920a;color:#1c1714">Today</div>
              </div>

              <!-- Greeting -->
              <div class="px-4 pb-2">
                <p class="text-[10px]" style="color:var(--ph-muted)">🌙 Good evening</p>
              </div>

              <!-- Ring + Macros — real app layout -->
              <div class="flex items-center justify-center px-3 pb-2 gap-4">
                <div class="relative flex-shrink-0" style="width:108px;height:108px">
                  <svg class="absolute inset-0" width="108" height="108" viewBox="0 0 108 108" style="transform:rotate(-90deg)" aria-hidden="true">
                    <circle cx="54" cy="54" r="45" fill="none" stroke="var(--ph-border)" stroke-width="9"/>
                    <circle cx="54" cy="54" r="45" fill="none" stroke="#c8920a" stroke-width="9" stroke-linecap="round" stroke-dasharray="283" stroke-dashoffset="14"/>
                  </svg>
                  <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span class="text-xl font-black" style="color:var(--ph-fg)">1,663</span>
                    <span class="text-[8px] font-bold" style="color:#c8920a">KCAL</span>
                    <span class="text-[7px]" style="color:var(--ph-muted)">5 left</span>
                  </div>
                </div>
                <div class="flex flex-col gap-2.5">
                  {[
                    { label:'Protein', val:'71g', left:'5g left',  color:'#60a5fa', fill:93 },
                    { label:'Carbs',   val:'145g',left:'10g left', color:'#fb923c', fill:94 },
                    { label:'Fat',     val:'46g', left:'2g left',  color:'#cb9ad8', fill:96 },
                  ].map(({ label, val, left, color, fill }) => (
                    <div class="flex items-center gap-2">
                      <div class="relative overflow-hidden flex-shrink-0" style={`width:12px;height:30px;border-radius:6px;border:1.5px solid ${color}40;background:${color}12`}>
                        <div class="absolute bottom-0 left-0 right-0" style={`height:${fill}%;background:${color}cc`}></div>
                      </div>
                      <div>
                        <p class="text-[7px]" style="color:var(--ph-muted)">{label}</p>
                        <p class="text-[9px] font-semibold" style="color:var(--ph-fg)">{val}</p>
                        <p class="text-[7px]" style="color:var(--ph-muted)">{left}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Today's Log -->
              <div class="px-3 pb-2 flex-1 overflow-hidden">
                <p class="text-[7px] font-bold uppercase tracking-widest mb-1.5" style="color:var(--ph-muted)">TODAY'S LOG</p>
                <!-- Item 1 -->
                <div class="rounded-xl p-2 mb-1.5" style="background:var(--ph-surface);border-left:2.5px solid #c8920a;border-top:1px solid var(--ph-border);border-right:1px solid var(--ph-border);border-bottom:1px solid var(--ph-border)">
                  <div class="flex items-start justify-between gap-1.5">
                    <p class="text-[9px] font-semibold flex-1 leading-tight" style="color:var(--ph-fg)">Grilled chicken (200g) · Rice (150g)<span class="ml-1 rounded-full px-1.5 py-0.5 text-[7px]" style="background:var(--ph-border);color:#c8920a">+1 more</span></p>
                    <div class="flex-shrink-0 text-right">
                      <p class="text-[10px] font-bold" style="color:#c8920a">892</p>
                      <p class="text-[7px]" style="color:var(--ph-muted)">kcal</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-1.5 mt-1">
                    <p class="text-[7px]" style="color:var(--ph-muted)">12:30</p>
                    <span class="text-[7px] font-medium" style="color:#60a5fa">●45g</span>
                    <span class="text-[7px] font-medium" style="color:#fb923c">●89g</span>
                    <span class="text-[7px] font-medium" style="color:#cb9ad8">●28g</span>
                  </div>
                </div>
                <!-- Item 2 -->
                <div class="rounded-xl px-2.5 py-2" style="background:var(--ph-surface);border-left:2.5px solid #c8920a;border-top:1px solid var(--ph-border);border-right:1px solid var(--ph-border);border-bottom:1px solid var(--ph-border)">
                  <div class="flex items-start justify-between gap-1.5">
                    <p class="text-[9px] font-semibold flex-1 leading-tight" style="color:var(--ph-fg)">Scrambled eggs (110g) · Sourdough (110g)</p>
                    <div class="flex-shrink-0 text-right">
                      <p class="text-[10px] font-bold" style="color:#c8920a">480</p>
                      <p class="text-[7px]" style="color:var(--ph-muted)">kcal</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-1.5 mt-1">
                    <p class="text-[7px]" style="color:var(--ph-muted)">08:30</p>
                    <span class="text-[7px] font-medium" style="color:#60a5fa">●26g</span>
                    <span class="text-[7px] font-medium" style="color:#fb923c">●56g</span>
                    <span class="text-[7px] font-medium" style="color:#cb9ad8">●18g</span>
                  </div>
                </div>
              </div>

              <!-- Input bar — mt-auto pins it to bottom in flex-col -->
              <div class="mt-auto px-3 pb-1">
                <div class="flex items-center gap-2">
                  <!-- Main input area with mic inside -->
                  <div class="relative flex-1 rounded-xl px-3 py-3 pr-10" style="background:var(--ph-surface);border:1px solid var(--ph-border);min-height:46px">
                    <p class="text-[10px] italic" style="color:var(--ph-placeholder)">2 eggs, toast and butter</p>
                    <!-- Mic inside input -->
                    <div class="absolute right-2 top-1/2 -translate-y-1/2 flex h-7 w-7 items-center justify-center rounded-full">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="color:var(--ph-muted)" aria-hidden="true">
                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                      </svg>
                    </div>
                  </div>
                  <!-- Submit button (separate square, mustard) -->
                  <div class="flex h-[38px] w-[38px] flex-shrink-0 items-center justify-center rounded-xl font-black text-base text-[#1c1714]" style="background:#c8920a">+</div>
                </div>
              </div>
              <div class="flex items-center justify-between px-4 pb-4">
                <span class="text-[9px] font-semibold" style="color:#c8920a">⊕ Add manually</span>
                <span class="text-[9px]" style="color:var(--ph-muted)">⚡ Unlimited · Supporter</span>
              </div>

            </div>
          </div>

          <!-- Floating badges -->
          <div class="absolute -left-8 top-16 rounded-2xl shadow-xl p-3 hidden sm:block bg-white dark:bg-[#1a1a1a]" style="border:1px solid #d4ccc4">
            <div class="flex items-center gap-2">
              <div class="flex h-8 w-8 items-center justify-center rounded-xl" style="background:#f4f2ef">
                <!-- shield-checkmark-outline -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8920a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold" style="color:#1c1714">100% Private</p>
                <p class="text-[10px]" style="color:#6b6560">Device-only storage</p>
              </div>
            </div>
          </div>

          <div class="absolute -right-8 bottom-24 rounded-2xl shadow-xl p-3 hidden sm:block bg-white dark:bg-[#1a1a1a]" style="border:1px solid #d4ccc4">
            <div class="flex items-center gap-2">
              <div class="flex h-8 w-8 items-center justify-center rounded-xl" style="background:#f4f2ef">
                <!-- flash-outline -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8920a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold" style="color:#1c1714">Instant AI</p>
                <p class="text-[10px]" style="color:#6b6560">&lt; 1 second</p>
              </div>
            </div>
          </div>

        </div>
      </AnimatedSection>

    </div>
  </div>
</section>
