---
import AnimatedSection from './AnimatedSection.tsx';
import PhoneMockupShell from './PhoneMockupShell.astro';
import PhoneVoiceInput from './mockups/PhoneVoiceInput.astro';
---

<section class="relative overflow-hidden bg-[#f4f2ef] dark:bg-[#0a0a0a] pt-16 pb-24 sm:pt-24 sm:pb-32">
  <!-- Subtle bg texture -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-32 w-[500px] h-[500px] rounded-full" style="background:radial-gradient(circle,rgba(200,146,10,0.12) 0%,transparent 70%)"></div>
    <div class="absolute -bottom-20 -left-32 w-[400px] h-[400px] rounded-full" style="background:radial-gradient(circle,rgba(200,146,10,0.08) 0%,transparent 70%)"></div>
    <div class="absolute inset-0 bg-hero-pattern opacity-25"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text -->
      <div class="text-center lg:text-left">


        <!-- Headline -->
        <AnimatedSection animation="fadeUp" delay={0.1} client:load>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-[#1c1714] dark:text-white leading-[1.05] mb-4">
            Type it. Say it.
            <br />
            <span style="color:#c8920a">NomsAI handles the rest.</span>
          </h1>
        </AnimatedSection>

        <!-- Sub -->
        <AnimatedSection animation="fadeUp" delay={0.2} client:load>
          <p class="text-lg text-[#6b6560] dark:text-[#9ca3af] leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
            The <strong class="text-[#1c1714] dark:text-white font-semibold">AI calorie tracker</strong> that logs a meal in 3 seconds.
            Free. No account.
          </p>
        </AnimatedSection>

        <!-- CTAs -->
        <AnimatedSection animation="fadeUp" delay={0.25} client:load>
          <div id="hero-ctas" class="flex flex-row items-center justify-center lg:justify-start gap-3 mb-6">

            <!-- App Store badge -->
            <a
              href="https://apps.apple.com/app/nomsai-ai-calorie-counter/id6771914399"
              target="_blank" rel="noopener noreferrer"
              class="hover:scale-[1.03] active:scale-[0.97] transition-transform duration-150 flex-shrink-0"
              style="background:#000;border-radius:10px;padding:10px 16px 10px 13px;display:inline-flex;align-items:center;gap:11px;border:1px solid rgba(255,255,255,0.15)"
              aria-label="Download on the App Store"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <div style="text-align:left;line-height:1.2">
                <div style="color:rgba(255,255,255,0.72);font-size:11px;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:0.03em">Download on the</div>
                <div style="color:#fff;font-size:19px;font-weight:600;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:-0.01em">App Store</div>
              </div>
            </a>

            <!-- Google Play badge -->
            <a
              href="https://play.google.com/store/apps/details?id=app.nomsai&hl=en"
              target="_blank" rel="noopener noreferrer"
              class="hover:scale-[1.03] active:scale-[0.97] transition-transform duration-150 flex-shrink-0"
              style="background:#000;border-radius:10px;padding:10px 16px 10px 13px;display:inline-flex;align-items:center;gap:11px;border:1px solid rgba(255,255,255,0.15)"
              aria-label="Get it on Google Play"
            >
              <svg width="24" height="26" viewBox="0 0 24 26" fill="none" aria-hidden="true">
                <path d="M1.22 0.56C0.8 0.99 0.56 1.67 0.56 2.55V23.43C0.56 24.31 0.8 24.99 1.22 25.42L1.31 25.51L12.72 14.1V13.85L1.31 2.47Z" fill="#4285F4"/>
                <path d="M16.54 17.93L12.72 14.1V13.85L16.54 10.02L16.65 10.08L21.19 12.67C22.47 13.39 22.47 14.56 21.19 15.28L16.65 17.87Z" fill="#FBBC04"/>
                <path d="M16.65 17.87L12.72 13.97L1.22 25.42C1.65 25.87 2.36 25.93 3.17 25.47L16.65 17.87Z" fill="#EA4335"/>
                <path d="M16.65 10.08L3.17 2.48C2.36 2.02 1.65 2.09 1.22 2.54L12.72 13.97Z" fill="#34A853"/>
              </svg>
              <div style="text-align:left;line-height:1.2">
                <div style="color:rgba(255,255,255,0.72);font-size:11px;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:0.03em">Get it on</div>
                <div style="color:#fff;font-size:19px;font-weight:600;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:-0.01em">Google Play</div>
              </div>
            </a>

          </div>
        </AnimatedSection>

        <!-- Rating -->
        <AnimatedSection animation="fadeUp" delay={0.3} client:load>
          <div class="flex items-center justify-center lg:justify-start gap-2.5 mb-8 flex-wrap">
            <div class="flex items-center gap-0.5" aria-hidden="true">
              {Array.from({ length: 5 }).map(() => (
                <svg class="h-[18px] w-[18px]" viewBox="0 0 20 20" fill="#c8920a">
                  <path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.51L10 14.6l-4.94 2.6.94-5.51-4-3.9 5.53-.8L10 1.5z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-medium text-[#6b6560] dark:text-[#9ca3af]">
              Loved by early users on the App Store &amp; Google Play
            </span>
          </div>
        </AnimatedSection>

        <!-- Feature rows -->
        <AnimatedSection animation="fadeUp" delay={0.35} client:load>
          <div class="flex flex-col gap-3 mb-10 max-w-sm mx-auto lg:mx-0">

            <!-- Meal ideas -->
            <div class="flex items-center gap-3 rounded-2xl bg-[#edeae5] dark:bg-[#1a1a1a] border border-[#d4ccc4] dark:border-[#2a2a2a] px-4 py-3">
              <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#1c1714] dark:bg-[#2a2a2a]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 18h6"/>
                  <path d="M10 22h4"/>
                  <path d="M12 2a7 7 0 0 0-4 12.74V17a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-2.26A7 7 0 0 0 12 2z"/>
                </svg>
              </div>
              <div class="text-left">
                <p class="text-sm font-bold text-[#1c1714] dark:text-white">Meal ideas</p>
                <p class="text-xs text-[#6b6560] dark:text-[#9ca3af]">Suggestions to hit your remaining macros</p>
              </div>
            </div>

            <!-- Workouts auto-sync -->
            <div class="flex items-center gap-3 rounded-2xl bg-[#edeae5] dark:bg-[#1a1a1a] border border-[#d4ccc4] dark:border-[#2a2a2a] px-4 py-3">
              <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#1c1714] dark:bg-[#2a2a2a]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="13" cy="4" r="1.5"/>
                  <path d="M4 17l5 1 .75-1.5"/>
                  <path d="M15 21v-4l-4-3 1-6"/>
                  <path d="M7 12V9l5-1 3 3 3 1"/>
                </svg>
              </div>
              <div class="text-left">
                <p class="text-sm font-bold text-[#1c1714] dark:text-white">Workouts sync automatically</p>
                <p class="text-xs text-[#6b6560] dark:text-[#9ca3af]">Imports from Apple Health</p>
              </div>
            </div>

            <!-- No account, free -->
            <div class="flex items-center gap-3 rounded-2xl bg-[#edeae5] dark:bg-[#1a1a1a] border border-[#d4ccc4] dark:border-[#2a2a2a] px-4 py-3">
              <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#1c1714] dark:bg-[#2a2a2a]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
              </div>
              <div class="text-left">
                <p class="text-sm font-bold text-[#1c1714] dark:text-white">No account · Free</p>
                <p class="text-xs text-[#6b6560] dark:text-[#9ca3af]">Everything stays on your phone</p>
              </div>
            </div>
          </div>
        </AnimatedSection>

      </div>

      <!-- Right: Phone mockup — matches real app UI exactly -->
      <AnimatedSection animation="slideLeft" delay={0.2} client:load>
        <div class="relative mx-auto w-[280px] sm:w-[320px]">
          <PhoneMockupShell>
            <PhoneVoiceInput />
          </PhoneMockupShell>

          <!-- Floating badges -->
          <div class="absolute -left-8 top-16 rounded-2xl shadow-xl p-3 hidden sm:block bg-white dark:bg-[#1a1a1a] border border-[#d4ccc4] dark:border-[#2a2a2a]">
            <div class="flex items-center gap-2">
              <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-[#f4f2ef] dark:bg-[#2a2a2a]">
                <!-- shield-checkmark-outline -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8920a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold text-[#1c1714] dark:text-white">100% Private</p>
                <p class="text-[10px] text-[#6b6560] dark:text-[#9ca3af]">Device-only storage</p>
              </div>
            </div>
          </div>

          <div class="absolute -right-8 bottom-24 rounded-2xl shadow-xl p-3 hidden sm:block bg-white dark:bg-[#1a1a1a] border border-[#d4ccc4] dark:border-[#2a2a2a]">
            <div class="flex items-center gap-2">
              <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-[#f4f2ef] dark:bg-[#2a2a2a]">
                <!-- flash-outline -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8920a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold text-[#1c1714] dark:text-white">Instant logging</p>
                <p class="text-[10px] text-[#6b6560] dark:text-[#9ca3af]">~3 seconds</p>
              </div>
            </div>
          </div>

        </div>
      </AnimatedSection>

    </div>
  </div>
</section>
