---
interface Props {
  variant?: 'hero' | 'section';
}
const { variant = 'section' } = Astro.props;
---

{variant === 'section' ? (
  <section id="download" class="py-20 sm:py-28 relative overflow-hidden" style="background:#1a1a1a">
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full blur-3xl" style="background:rgba(200,146,10,0.08)"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 rounded-full blur-3xl" style="background:rgba(200,146,10,0.05)"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2.5 mb-6">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl text-3xl shadow-lg" style="background-color:#c8920a;box-shadow:0 4px 20px rgba(200,146,10,0.35)">
            🍽️
          </div>
        </div>
        <p class="text-sm font-bold uppercase tracking-widest mb-3" style="color:#c8920a">Get the app</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white tracking-tight mb-4">
          Start tracking today.
          <span style="color:#c8920a"> Free.</span>
        </h2>
        <p class="text-lg max-w-xl mx-auto" style="color:#9ca3af">
          Download NomsAI and log your first meal in under 30 seconds. No account, no setup, no friction.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <!-- App Store -->
        <a href="#" aria-label="Download NomsAI on the App Store"
          class="group flex items-center gap-4 rounded-2xl border px-6 py-4 transition-all duration-200 hover:scale-[1.02] active:scale-[0.99]"
          style="background:rgba(255,255,255,0.07);border-color:rgba(255,255,255,0.12)">
          <svg class="h-10 w-10 text-white flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div class="text-left">
            <p class="text-xs leading-tight" style="color:#9ca3af">Download on the</p>
            <p class="text-xl font-bold text-white leading-tight">App Store</p>
          </div>
        </a>

        <!-- Google Play -->
        <a href="#" aria-label="Download NomsAI on Google Play"
          class="group flex items-center gap-4 rounded-2xl border px-6 py-4 transition-all duration-200 hover:scale-[1.02] active:scale-[0.99]"
          style="background:rgba(255,255,255,0.07);border-color:rgba(255,255,255,0.12)">
          <svg class="h-10 w-10 text-white flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3.18 23.76c.3.17.66.19.99.08l12.45-7.2-2.68-2.68-10.76 9.8zm-1.63-20.4C1.21 3.77 1 4.24 1 4.87v14.26c0 .63.21 1.1.55 1.42l.08.07 7.99-7.99v-.19L1.63 4.29l-.08.07zM20.96 10.16l-2.67-1.54-3 2.99 3 2.99 2.69-1.55c.76-.44.76-1.45-.02-1.89zM4.17.24L16.62 7.44 13.94 10.12 3.18.32c.33-.11.7-.09.99.08v-.16z"/>
          </svg>
          <div class="text-left">
            <p class="text-xs leading-tight" style="color:#9ca3af">Get it on</p>
            <p class="text-xl font-bold text-white leading-tight">Google Play</p>
          </div>
        </a>
      </div>

      <!-- Trust signals -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-6 text-sm" style="color:#9ca3af">
        {[
          { icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z', label: 'Free to download' },
          { icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', label: 'No account required' },
          { icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z', label: 'iOS & Android' },
        ].map(({ icon, label }) => (
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="#c8920a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={icon}/>
            </svg>
            {label}
          </span>
        ))}
      </div>
    </div>
  </section>
) : (
  <div class="flex flex-col sm:flex-row items-center gap-3">
    <a href="#download" aria-label="Download NomsAI on the App Store"
      class="flex items-center gap-3 rounded-xl px-5 py-3 hover:opacity-90 active:scale-95 transition-all duration-200"
      style="background:#1c1714">
      <svg class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      <div>
        <p class="text-[10px]" style="color:#9ca3af">Download on the</p>
        <p class="text-base font-bold text-white leading-tight">App Store</p>
      </div>
    </a>
    <a href="#download" aria-label="Download NomsAI on Google Play"
      class="flex items-center gap-3 rounded-xl px-5 py-3 hover:opacity-90 active:scale-95 transition-all duration-200"
      style="background:#1c1714">
      <svg class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M3.18 23.76c.3.17.66.19.99.08l12.45-7.2-2.68-2.68-10.76 9.8zm-1.63-20.4C1.21 3.77 1 4.24 1 4.87v14.26c0 .63.21 1.1.55 1.42l.08.07 7.99-7.99v-.19L1.63 4.29l-.08.07zM20.96 10.16l-2.67-1.54-3 2.99 3 2.99 2.69-1.55c.76-.44.76-1.45-.02-1.89zM4.17.24L16.62 7.44 13.94 10.12 3.18.32c.33-.11.7-.09.99.08v-.16z"/>
      </svg>
      <div>
        <p class="text-[10px]" style="color:#9ca3af">Get it on</p>
        <p class="text-base font-bold text-white leading-tight">Google Play</p>
      </div>
    </a>
  </div>
)}
