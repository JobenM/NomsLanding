---
const navLinks = [
  { href: '/how-it-works', label: 'How It Works' },
  { href: '/faq', label: 'FAQ' },
  { href: '/articles', label: 'Articles' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full border-b backdrop-blur-xl backdrop-saturate-150 transition-colors duration-300"
  style="border-color:rgba(212,204,196,0.5);background:rgba(244,242,239,0.85)"
  id="site-header">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">

      <!-- Logo — mustard square + 🍽️ emoji, matches AppLogo.tsx exactly -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="NomsAI home">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl text-xl shadow-sm transition-transform duration-200 group-hover:scale-105"
          style="background-color:#c8920a;box-shadow:0 2px 8px rgba(200,146,10,0.3)">
          🍽️
        </div>
        <span class="text-lg font-black tracking-tight text-[#1c1714] dark:text-white transition-colors duration-200">
          NomsAI
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
              currentPath === href || currentPath.startsWith(href + '/')
                ? 'font-semibold'
                : 'text-[#6b6560] dark:text-[#9ca3af] hover:text-[#1c1714] dark:hover:text-white hover:bg-[#edeae5] dark:hover:bg-[#1a1a1a]',
            ]}
            style={currentPath === href || currentPath.startsWith(href + '/') ? 'color:#c8920a;background:rgba(200,146,10,0.08)' : ''}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- CTA + Theme Toggle -->
      <div class="hidden md:flex items-center gap-3">
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="rounded-lg p-2 transition-all duration-200 hover:bg-[#edeae5] dark:hover:bg-[#1a1a1a]"
          style="color:#6b6560"
        >
          <!-- Moon (shows in light mode) -->
          <svg class="h-5 w-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
          <!-- Sun (shows in dark mode) -->
          <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
        </button>

        <a
          href="#download"
          class="inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-bold text-[#1c1714] shadow-sm active:scale-95 transition-all duration-200"
          style="background-color:#c8920a"
        >
          Download App
        </a>
      </div>

      <!-- Mobile -->
      <div class="md:hidden flex items-center gap-2">
        <button
          id="theme-toggle-mobile"
          aria-label="Toggle dark mode"
          class="rounded-lg p-2 transition-colors duration-200 hover:bg-[#edeae5] dark:hover:bg-[#1a1a1a]"
          style="color:#6b6560"
        >
          <svg class="h-5 w-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
          <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
        </button>

        <label for="mobile-menu-toggle" class="cursor-pointer rounded-lg p-2 hover:bg-[#edeae5] dark:hover:bg-[#1a1a1a] transition-colors duration-200" aria-label="Toggle menu">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:#6b6560" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </label>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" aria-hidden="true" />
  <div class="hidden peer-checked:block md:hidden border-t bg-[#f4f2ef] dark:bg-[#0a0a0a]" style="border-color:#d4ccc4">
    <nav class="mx-auto max-w-6xl px-4 py-4 flex flex-col gap-1" aria-label="Mobile navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-4 py-3 rounded-xl text-sm font-medium transition-all duration-200',
            currentPath === href || currentPath.startsWith(href + '/')
              ? 'font-semibold'
              : 'text-[#6b6560] dark:text-[#9ca3af] hover:bg-[#edeae5] dark:hover:bg-[#1a1a1a]',
          ]}
          style={currentPath === href || currentPath.startsWith(href + '/') ? 'color:#c8920a;background:rgba(200,146,10,0.08)' : ''}
        >
          {label}
        </a>
      ))}
      <div class="mt-2 pt-2 border-t" style="border-color:#d4ccc4">
        <a
          href="#download"
          class="block w-full text-center rounded-xl px-4 py-3 text-sm font-bold text-[#1c1714] transition-colors duration-200"
          style="background-color:#c8920a"
        >
          Download App
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  function applyDarkHeader() {
    const header = document.getElementById('site-header');
    if (!header) return;
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      header.style.borderColor = 'rgba(42,42,42,0.5)';
      header.style.background = 'rgba(10,10,10,0.85)';
    } else {
      header.style.borderColor = 'rgba(212,204,196,0.5)';
      header.style.background = 'rgba(244,242,239,0.85)';
    }
  }

  function initThemeToggle() {
    applyDarkHeader();
    const toggles = [
      document.getElementById('theme-toggle'),
      document.getElementById('theme-toggle-mobile'),
    ];
    toggles.forEach((toggle) => {
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        applyDarkHeader();
      });
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
