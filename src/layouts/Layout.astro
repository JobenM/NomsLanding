---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  ogImage = '/og-image.jpg',
  ogTitle,
  ogDescription,
  canonicalURL,
} = Astro.props;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;
const resolvedCanonical = canonicalURL ?? Astro.url.href;
const site = 'https://nomsai.app';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={resolvedOgTitle} />
    <meta name="description" content={description} />
    <meta name="author" content="NomsAI" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:image" content={`${site}${ogImage}`} />
    <meta property="og:image:secure_url" content={`${site}${ogImage}`} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="NomsAI" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={resolvedCanonical} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={`${site}${ogImage}`} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Per-page structured data / JSON-LD -->
    <slot name="head" />


    <!-- Theme: default light, respect stored preference -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        if (stored !== 'light') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <style is:global>
    /* Phone mockup theme — mirrors actual NomsAI app colors */
    :root {
      --ph-bg: #f4f2ef;
      --ph-surface: #edeae5;
      --ph-border: #d4ccc4;
      --ph-fg: #1c1714;
      --ph-muted: #6b6560;
      --ph-placeholder: #bbb5af;
    }
    .dark {
      --ph-bg: #0a0a0a;
      --ph-surface: #1a1a1a;
      --ph-border: #2a2a2a;
      --ph-fg: #ffffff;
      --ph-muted: #9ca3af;
      --ph-placeholder: #6b7280;
    }

    /* Sticky mobile CTA bar theming */
    :root { --sticky-bar-bg: rgba(244,242,239,0.96); --sticky-bar-border: #d4ccc4; }
    .dark { --sticky-bar-bg: rgba(10,10,10,0.96); --sticky-bar-border: #2a2a2a; }

    /* prose-legal — dark-mode-aware legal document styles */
    .prose-legal h2 { font-size:1.25rem;font-weight:800;color:#1c1714;margin-top:2.5rem;margin-bottom:.75rem;letter-spacing:-.01em; }
    .prose-legal h3 { font-size:1.05rem;font-weight:700;color:#1c1714;margin-top:1.75rem;margin-bottom:.5rem; }
    .prose-legal p  { color:#6b6560;line-height:1.8;margin-bottom:1rem; }
    .prose-legal a  { color:#c8920a;font-weight:500; }
    .prose-legal a:hover { text-decoration:underline; }
    .prose-legal ul,.prose-legal ol { color:#6b6560;padding-left:1.5rem;margin-bottom:1rem; }
    .prose-legal li { margin-bottom:.4rem;line-height:1.8; }
    .prose-legal strong { color:#1c1714; }
    .prose-legal code { color:#c8920a;background:#edeae5;padding:.1rem .35rem;border-radius:.25rem;font-size:.875em; }
    html.dark .prose-legal h2,
    html.dark .prose-legal h3,
    html.dark .prose-legal strong { color:#ffffff; }
    html.dark .prose-legal p,
    html.dark .prose-legal li { color:#9ca3af; }
    html.dark .prose-legal code { background:#1a1a1a; }
  </style>
  <body class="bg-[#f4f2ef] dark:bg-[#0a0a0a] text-[#1c1714] dark:text-white antialiased transition-colors duration-300">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Mobile sticky download bar — hidden until hero CTAs scroll out of view -->
    <div
      id="sticky-cta"
      class="fixed bottom-0 left-0 right-0 z-40 sm:hidden"
      aria-hidden="false"
      style="background:var(--sticky-bar-bg);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-top:1px solid var(--sticky-bar-border);padding:10px 12px env(safe-area-inset-bottom,12px);transform:translateY(0);opacity:1;transition:transform 0.4s cubic-bezier(0.4,0,0.2,1),opacity 0.4s ease"
    >
      <div class="flex flex-row gap-4 items-center justify-center">

        <!-- App Store badge -->
        <a
          href="https://apps.apple.com/gb/app/nomsai-ai-calorie-counter/id6771914399"
          target="_blank" rel="noopener noreferrer"
          style="background:#000;border-radius:10px;padding:10px 18px 10px 14px;display:inline-flex;align-items:center;justify-content:center;gap:11px;border:1px solid rgba(255,255,255,0.15);flex:1"
          aria-label="Download on the App Store"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div style="text-align:left;line-height:1.2">
            <div style="color:rgba(255,255,255,0.72);font-size:11px;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:0.03em">Download on the</div>
            <div style="color:#fff;font-size:20px;font-weight:600;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:-0.01em">App Store</div>
          </div>
        </a>

        <!-- Google Play badge -->
        <a
          href="https://play.google.com/store/apps/details?id=app.nomsai&hl=en"
          target="_blank" rel="noopener noreferrer"
          style="background:#000;border-radius:10px;padding:10px 18px 10px 14px;display:inline-flex;align-items:center;justify-content:center;gap:11px;border:1px solid rgba(255,255,255,0.15);flex:1"
          aria-label="Get it on Google Play"
        >
          <svg width="24" height="26" viewBox="0 0 24 26" fill="none" aria-hidden="true">
            <path d="M1.22 0.56C0.8 0.99 0.56 1.67 0.56 2.55V23.43C0.56 24.31 0.8 24.99 1.22 25.42L1.31 25.51L12.72 14.1V13.85L1.31 2.47Z" fill="#4285F4"/>
            <path d="M16.54 17.93L12.72 14.1V13.85L16.54 10.02L16.65 10.08L21.19 12.67C22.47 13.39 22.47 14.56 21.19 15.28L16.65 17.87Z" fill="#FBBC04"/>
            <path d="M16.65 17.87L12.72 13.97L1.22 25.42C1.65 25.87 2.36 25.93 3.17 25.47L16.65 17.87Z" fill="#EA4335"/>
            <path d="M16.65 10.08L3.17 2.48C2.36 2.02 1.65 2.09 1.22 2.54L12.72 13.97Z" fill="#34A853"/>
          </svg>
          <div style="text-align:left;line-height:1.2">
            <div style="color:rgba(255,255,255,0.72);font-size:11px;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:0.03em">Get it on</div>
            <div style="color:#fff;font-size:20px;font-weight:600;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;letter-spacing:-0.01em;white-space:nowrap">Google Play</div>
          </div>
        </a>

      </div>
    </div>

    <script is:inline>
      (function () {
        var bar = document.getElementById('sticky-cta');
        var heroCtas = document.getElementById('hero-ctas');
        if (!bar || !heroCtas) return;

        var observer = new IntersectionObserver(function (entries) {
          var visible = entries[0].isIntersecting;
          // Hide bar when hero CTAs are on-screen; show when they've scrolled away
          if (visible) {
            bar.style.transform = 'translateY(100%)';
            bar.style.opacity = '0';
            bar.setAttribute('aria-hidden', 'true');
          } else {
            bar.style.transform = 'translateY(0)';
            bar.style.opacity = '1';
            bar.setAttribute('aria-hidden', 'false');
          }
        }, { threshold: 0 });

        observer.observe(heroCtas);
      })();
    </script>

    <!-- Coming Soon Modal — shared across all pages -->
    <div id="coming-soon-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4" style="display:none!important">
      <div id="modal-backdrop" class="absolute inset-0" style="background:rgba(0,0,0,0.7);backdrop-filter:blur(4px)"></div>
      <div class="relative w-full max-w-sm rounded-3xl p-8 text-center shadow-2xl" style="background:#1a1a1a;border:1px solid rgba(255,255,255,0.1)">
        <button id="modal-close" class="absolute top-4 right-4 flex h-8 w-8 items-center justify-center rounded-full transition-colors" style="background:rgba(255,255,255,0.08);color:#9ca3af">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>

        <div class="mb-5 flex justify-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl text-4xl" style="background:rgba(200,146,10,0.15);box-shadow:0 0 0 1px rgba(200,146,10,0.3)">
            <span id="modal-icon">🍎</span>
          </div>
        </div>

        <p class="mb-1 text-xs font-bold uppercase tracking-widest" style="color:#c8920a">Coming Soon</p>
        <h3 id="modal-title" class="mb-3 text-2xl font-extrabold text-white">App Store</h3>
        <p id="modal-body" class="text-base leading-relaxed" style="color:#9ca3af">
          We're putting the finishing touches on the build. It'll be worth the wait.
        </p>

        <button id="modal-dismiss" class="mt-7 w-full rounded-2xl py-3.5 text-base font-bold transition-opacity hover:opacity-90" style="background:#c8920a;color:#1c1714">
          Got it
        </button>
      </div>
    </div>

    <script>
      const PLATFORMS: Record<string, { icon: string; title: string; body: string }> = {
        ios: {
          icon: '🍎',
          title: 'App Store',
          body: "We're putting the finishing touches on the iOS build. It'll be worth the wait.",
        },
        android: {
          icon: '🤖',
          title: 'Google Play',
          body: "We're putting the finishing touches on the Android build. It'll be worth the wait.",
        },
        both: {
          icon: '📱',
          title: 'iOS & Android',
          body: "We're putting the finishing touches on both builds. It'll be worth the wait.",
        },
      };

      const modal = document.getElementById('coming-soon-modal') as HTMLElement;
      const backdrop = document.getElementById('modal-backdrop') as HTMLElement;
      const closeBtn = document.getElementById('modal-close') as HTMLElement;
      const dismissBtn = document.getElementById('modal-dismiss') as HTMLElement;
      const modalIcon = document.getElementById('modal-icon') as HTMLElement;
      const modalTitle = document.getElementById('modal-title') as HTMLElement;
      const modalBody = document.getElementById('modal-body') as HTMLElement;

      function openModal(platform: string) {
        const config = PLATFORMS[platform] ?? PLATFORMS.both;
        modalIcon.textContent = config.icon;
        modalTitle.textContent = config.title;
        modalBody.textContent = config.body;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        modal.style.display = 'none';
        document.body.style.overflow = '';
      }

      document.querySelectorAll('[data-platform]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          openModal((btn as HTMLElement).dataset.platform ?? 'both');
        });
      });

      backdrop.addEventListener('click', closeModal);
      closeBtn.addEventListener('click', closeModal);
      dismissBtn.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    </script>
  </body>
</html>
