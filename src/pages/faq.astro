---
import Layout from '../layouts/Layout.astro';
import AnimatedSection from '../components/AnimatedSection.tsx';
import AppStoreBadges from '../components/AppStoreBadges.astro';

const faqCategories = [
  {
    category: 'Privacy & Data',
    faqs: [
      {
        question: 'Where is my food data stored?',
        answer: 'Your entire food diary is stored locally on your device — your iPhone or Android phone. Nothing is ever uploaded to our servers. We have no cloud database containing your meals. We cannot see your food log, and neither can anyone else. If you uninstall the app, your data is completely gone with no lingering records anywhere.',
      },
      {
        question: 'Do you sell my data to advertisers?',
        answer: 'No. We do not sell, share, rent, or monetize your data in any way. We do not have a user database of meals or nutrition logs. There is nothing to sell. Our business model is the app itself — not your personal information.',
      },
      {
        question: 'Do you require any account or login?',
        answer: 'No account, email, or login is required to use NomsAI. You download the app and start logging immediately. We do not collect personally identifiable information. The only identifier used is an anonymous device UUID — no name, email, or personal data is ever collected.',
      },
    ],
  },
  {
    category: 'Pricing & Credits',
    faqs: [
      {
        question: 'Is NomsAI free?',
        answer: 'Yes — you can start logging immediately with no payment required. When you first open the app you receive 20 Welcome Credits (a one-time fuel tank to get you started). After those are used, you get 5 free daily logs every day, automatically refilled at midnight. If you need more, you can top up with Emergency Credits (a small one-time purchase) or unlock unlimited logging with the Supporter Pass — a monthly or annual subscription.',
      },
      {
        question: 'What is the Supporter Pass?',
        answer: 'The Supporter Pass is an optional subscription that gives you unlimited food logs with no daily cap. It\'s the best option if you log more than 5 meals a day or want to track snacks and drinks freely. Subscriptions are managed through Apple or Google and can be cancelled at any time.',
      },
      {
        question: 'What are Emergency Credits?',
        answer: 'Emergency Credits are a one-time top-up you can purchase if you run out of daily free logs and don\'t want a subscription. They\'re consumed one per AI log entry and never expire. Useful for occasional heavy-logging days without committing to a subscription.',
      },
    ],
  },
  {
    category: 'AI Accuracy',
    faqs: [
      {
        question: 'How accurate is the AI calorie estimation?',
        answer: 'For common foods and meals, NomsAI estimates are typically within 15–20% of actual calorie and macro values — similar to how most people estimate their own intake from memory. The app uses Google Gemini with a UK food database for lookup. For nutritional awareness and trend tracking, this level of accuracy is more than sufficient. Consistency matters more than perfection.',
      },
      {
        question: 'What types of food descriptions work best?',
        answer: 'Natural, descriptive language works best. Include the food name, cooking method if relevant (grilled, fried, raw), and an approximate quantity (bowl of, two slices, handful, large plate). Restaurant meals work well if you name the restaurant and dish. The more context you provide, the better the estimate.',
      },
      {
        question: 'Can it handle mixed dishes and restaurant meals?',
        answer: 'Yes. NomsAI is designed for real-world eating, not just packaged foods with barcodes. It handles mixed dishes like "chicken stir fry with vegetables and rice", restaurant orders like "large burger and chips meal", and foods from around the world. It won\'t always be perfect, but it provides a useful estimate you can adjust before saving.',
      },
      {
        question: 'Why are estimates sometimes different for the same food?',
        answer: 'Small variations in your description, portion size wording, or cooking method can yield slightly different estimates — just as they would for any human estimating food. For consistent tracking, describe similar meals in similar ways.',
      },
    ],
  },
  {
    category: 'Offline & Technical',
    faqs: [
      {
        question: 'Does the app work offline?',
        answer: 'Your food log and all your data are always available offline — the app reads from local storage on your device. AI-powered parsing for new food entries requires a brief internet connection, but your existing log, daily totals, and history are fully functional without WiFi.',
      },
      {
        question: 'Is NomsAI available on both iOS and Android?',
        answer: 'Yes. NomsAI is available on the Apple App Store for iPhone and on Google Play for Android. The core experience is the same on both platforms.',
      },
      {
        question: 'What macros does NomsAI track?',
        answer: 'NomsAI tracks calories (kcal), protein (g), carbohydrates (g), and fat (g) for each logged meal. Daily totals are shown with a calorie ring and three macro rings — all on one screen. You can also log workouts and bodyweight separately.',
      },
    ],
  },
];
---

<Layout
  title="FAQ — NomsAI AI Calorie Tracker Questions Answered"
  description="Common questions about NomsAI answered: privacy, AI accuracy, offline use, no login required, supported foods, macro tracking, iOS and Android support, and data storage."
>

  <!-- Page Hero -->
  <section class="py-20 sm:py-28 border-b bg-white dark:bg-[#0a0a0a]" style="border-color:#d4ccc4">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <AnimatedSection animation="fadeUp" client:load>
        <p class="text-sm font-bold uppercase tracking-widest mb-4" style="color:#c8920a">FAQ</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-6" style="color:#1c1714">
          Frequently asked questions
        </h1>
        <p class="text-xl leading-relaxed" style="color:#6b6560">
          Everything you want to know about NomsAI — privacy, credits, AI accuracy, and more.
        </p>
      </AnimatedSection>
    </div>
  </section>

  <!-- FAQ Content -->
  <section class="py-20 sm:py-28 bg-[#f4f2ef] dark:bg-[#0a0a0a]">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">

      {faqCategories.map(({ category, faqs }) => (
        <AnimatedSection animation="fadeUp" client:load>
          <div class="mb-14">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-3" style="color:#1c1714">
              <span class="block h-px flex-1" style="background:#d4ccc4"></span>
              <span class="flex-shrink-0">{category}</span>
              <span class="block h-px flex-1" style="background:#d4ccc4"></span>
            </h2>
            <div class="space-y-3">
              {faqs.map(({ question, answer }) => (
                <details class="group rounded-2xl border overflow-hidden transition-colors duration-200 bg-white dark:bg-[#1a1a1a]"
                  style="border-color:#d4ccc4">
                  <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
                    <h3 class="text-base font-semibold pr-4" style="color:#1c1714">{question}</h3>
                    <div class="flex-shrink-0 flex h-8 w-8 items-center justify-center rounded-full transition-all duration-200"
                      style="background:#edeae5">
                      <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24"
                        stroke="#c8920a" stroke-width="2.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                      </svg>
                    </div>
                  </summary>
                  <div class="px-6 pb-6">
                    <p class="leading-relaxed text-sm" style="color:#6b6560">{answer}</p>
                  </div>
                </details>
              ))}
            </div>
          </div>
        </AnimatedSection>
      ))}

      <!-- Still have questions -->
      <AnimatedSection animation="fadeUp" client:load>
        <div class="rounded-3xl p-8 text-center" style="background:#c8920a">
          <h2 class="text-2xl font-bold mb-3 text-white">Still have a question?</h2>
          <p class="mb-6 text-sm" style="color:rgba(255,255,255,0.8)">Can't find what you're looking for? Reach out and we'll get back to you quickly.</p>
          <a
            href="mailto:hello@nomsai.app"
            class="inline-flex items-center gap-2 rounded-xl px-6 py-3 font-semibold transition-all duration-200 hover:opacity-90 active:scale-95"
            style="background:white;color:#c8920a"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            hello@nomsai.app
          </a>
        </div>
      </AnimatedSection>

    </div>
  </section>

  <AppStoreBadges variant="section" />

</Layout>
