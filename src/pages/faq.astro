---
import Layout from '../layouts/Layout.astro';
import AnimatedSection from '../components/AnimatedSection.tsx';
import AppStoreBadges from '../components/AppStoreBadges.astro';

const faqCategories: { category: string; faqs: { question: string; answer: string }[] }[] = [
  {
    category: 'Privacy & Data',
    faqs: [
      {
        question: 'Where is my food data stored?',
        answer: 'Your entire food diary is stored locally on your device — your iPhone or Android phone. Nothing is ever uploaded to our servers. We have no cloud database containing your meals. We cannot see your food log, and neither can anyone else. If you uninstall the app, your data is completely gone with no lingering records anywhere.',
      },
      {
        question: 'Does NomsAI see what I type into the app?',
        answer: 'No. The text you type is processed to estimate your macros and then immediately discarded — it is never stored on our servers, in any database, or in your food log. We made this a deliberate design decision: your food diary is yours and nobody else\'s business.',
      },
      {
        question: 'Do you sell my data to advertisers?',
        answer: 'No. We do not sell, share, rent, or monetise your data in any way. We do not have a user database of meals or nutrition logs. There is nothing to sell. Our business model is the app itself — not your personal information.',
      },
      {
        question: 'Do you require any account or login?',
        answer: 'No account, email, or login is ever required to use NomsAI. Download the app and start logging immediately. The only identifier used is an anonymous device ID — no name, email, or personal data is collected.',
      },
      {
        question: 'What happens to my data if I delete the app?',
        answer: 'Because your food logs live on your device, deleting the app removes them permanently. There is no cloud backup to recover from and no account to log back into — which is exactly how a privacy-first app should work. If you want to keep a copy before uninstalling, use Settings > Export to save your data first.',
      },
    ],
  },
  {
    category: 'Pricing & Credits',
    faqs: [
      {
        question: 'Is NomsAI free?',
        answer: 'Yes — you can start logging immediately with no payment required. When you first open the app you receive 20 Welcome Credits to get started. After those are used, you get 5 free AI logs every day, automatically refilled at midnight. If you need more, top up with Emergency Credits (a small one-time purchase) or unlock unlimited logging with Pro — available monthly or annually.',
      },
      {
        question: 'What is Pro?',
        answer: 'Pro is an optional subscription that removes the daily log limit entirely. It\'s the best option if you log more than 5 meals a day or want to track every snack and drink without thinking about credits. Subscriptions are managed through Apple or Google and can be cancelled at any time.',
      },
      {
        question: 'What are Emergency Credits?',
        answer: 'Emergency Credits are a one-time top-up you can purchase if you run out of daily free logs and don\'t want a subscription. They\'re consumed one per AI log entry, never expire, and are useful for occasional heavy-logging days without committing to a monthly plan.',
      },
      {
        question: 'What happens to my logs if I stop paying?',
        answer: 'Nothing. Your food logs are stored on your device and stay there regardless of your subscription status. Cancelling Pro means you return to the 5 free daily logs — your history is completely untouched.',
      },
    ],
  },
  {
    category: 'AI Accuracy',
    faqs: [
      {
        question: 'How accurate is the AI calorie estimation?',
        answer: 'For everyday foods and meals, estimates are close to what you\'d get estimating yourself — good enough to build meaningful nutritional awareness and track trends over time. Complex homemade dishes with lots of ingredients are harder to nail precisely, but that\'s true of any method short of weighing every component. Consistency matters far more than perfection: logging something approximate every day beats logging nothing because it feels too imprecise.',
      },
      {
        question: 'Can I correct the AI if it gets something wrong?',
        answer: 'Yes — and this is by design. Before anything is saved, a Review screen shows every item NomsAI identified with its estimated calories, protein, carbs, and fat. You can edit any number, adjust portion amounts, rename items, or remove something entirely. Nothing is logged until you tap Confirm. You stay in control of every entry.',
      },
      {
        question: 'How does it handle homemade meals?',
        answer: 'Describe it the way you\'d explain it to someone: what\'s in it, roughly how much of each thing, and how it was cooked. "Homemade chicken curry with rice, coconut milk, and vegetables — medium portion" will give a sensible estimate. It won\'t be perfectly precise, but it\'ll be in the right ballpark. You can always tweak the numbers on the Review screen before confirming.',
      },
      {
        question: 'What types of food descriptions work best?',
        answer: 'Natural, descriptive language works best. Include the food name, cooking method if relevant (grilled, fried, raw), and an approximate quantity (bowl of, two slices, handful, large plate). Restaurant meals work well if you name the restaurant and dish. The more context you give, the better the estimate.',
      },
      {
        question: 'Can it handle mixed dishes and restaurant meals?',
        answer: 'Yes. NomsAI is built for real-world eating, not just packaged foods with barcodes. It handles mixed dishes like "chicken stir fry with vegetables and rice", restaurant orders like "large burger and chips", and foods from cuisines around the world. It won\'t always be perfect, but you can adjust anything before saving.',
      },
      {
        question: 'Why are estimates sometimes different for the same food?',
        answer: 'Small variations in how you describe a meal — portion size wording, cooking method, or added ingredients — can yield slightly different estimates, just as they would for any human estimating food. For consistent tracking, describe similar meals in similar ways.',
      },
    ],
  },
  {
    category: 'Features & Logging',
    faqs: [
      {
        question: 'Can I log workouts too?',
        answer: 'Yes. Tap the + button and switch to the Workout tab to log activities like running, walking, cycling, strength training, and more. NomsAI estimates calories burned based on the activity type, duration, and your bodyweight. Burned calories appear alongside your food log so you can see your net intake for the day.',
      },
      {
        question: 'Does it track water intake?',
        answer: 'Yes. Water tracking is optional and off by default — turn it on in Settings if you want it. Once enabled, you can set a daily goal and log in preset amounts (150 ml, 250 ml, 500 ml, 750 ml) from the dashboard. Your progress shows as a simple bar throughout the day.',
      },
      {
        question: 'How does it handle water, black tea, diet soda, and other zero-calorie drinks?',
        answer: 'NomsAI recognises common zero-calorie drinks and logs them instantly without using a credit. Just type "black coffee", "water", "diet Coke", or similar and they\'re added to your log immediately — no AI processing, no credit deducted.',
      },
      {
        question: 'Can I add a meal from a previous day?',
        answer: 'Yes. Swipe or tap back through the date strip at the top of the dashboard to navigate to any previous day, then log normally. Entries are saved to whichever date you\'re currently viewing.',
      },
      {
        question: 'Can I save meals I eat regularly?',
        answer: 'Yes. After reviewing any meal, tap "Save as Recipe" to store it permanently under a name you choose. Next time, just type the recipe name and the whole meal logs in one tap — no re-entering ingredients.',
      },
      {
        question: 'Can I export my data?',
        answer: 'Yes. Go to Settings > Export Data to download your food logs as a CSV file — useful for sharing with a nutritionist or importing elsewhere. There\'s also a full JSON backup option under Settings > Backup & Restore that covers logs, workouts, weight entries, recipes, and goals.',
      },
      {
        question: 'Does NomsAI work outside the UK?',
        answer: 'Yes, NomsAI works worldwide. The app detects your region automatically and uses locally relevant food references. Whether you\'re in the US, Europe, Asia, or anywhere else, you can log in plain English (or describe foods in your own language) and get a useful estimate.',
      },
    ],
  },
  {
    category: 'Offline & Technical',
    faqs: [
      {
        question: 'Does the app work offline?',
        answer: 'Your food log and all your data are always available offline — the app reads from local storage on your device. AI-powered logging for new entries requires a brief internet connection, but your existing log, daily totals, and history are fully accessible without WiFi.',
      },
      {
        question: 'Is NomsAI available on both iOS and Android?',
        answer: 'Yes. NomsAI is available on the Apple App Store for iPhone and on Google Play for Android. The core experience is identical on both platforms.',
      },
      {
        question: 'What macros does NomsAI track?',
        answer: 'NomsAI tracks calories (kcal), protein (g), carbohydrates (g), and fat (g) for every logged meal. Daily totals are shown with a calorie ring and three macro rings — all visible on one screen. You can also log workouts and bodyweight separately for a complete daily picture.',
      },
    ],
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqCategories.flatMap(({ faqs }) =>
    faqs.map(({ question, answer }) => ({
      '@type': 'Question',
      name: question,
      acceptedAnswer: { '@type': 'Answer', text: answer },
    }))
  ),
};
---

<Layout
  title="FAQ — NomsAI | AI Calorie Tracker, No Account Required"
  description="Common questions about NomsAI: no account needed, AI accuracy, privacy-first data storage, free vs Pro, exporting data, workout logging, water tracking, and more."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Page Hero -->
  <section class="py-20 sm:py-28 border-b border-[#d4ccc4] dark:border-[#2a2a2a] bg-white dark:bg-[#0a0a0a]">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <AnimatedSection animation="fadeUp" client:load>
        <p class="text-sm font-bold uppercase tracking-widest mb-4" style="color:#c8920a">FAQ</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-6 text-[#1c1714] dark:text-white">
          Frequently asked questions
        </h1>
        <p class="text-xl leading-relaxed text-[#6b6560] dark:text-[#9ca3af]">
          Everything you want to know about NomsAI — privacy, credits, AI accuracy, and more.
        </p>
      </AnimatedSection>
    </div>
  </section>

  <!-- FAQ Content -->
  <section class="py-20 sm:py-28 bg-[#f4f2ef] dark:bg-[#0a0a0a]">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">

      {faqCategories.map(({ category, faqs }) => (
        <AnimatedSection animation="fadeUp" client:load>
          <div class="mb-14">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-3 text-[#1c1714] dark:text-white">
              <span class="block h-px flex-1 bg-[#d4ccc4] dark:bg-[#2a2a2a]"></span>
              <span class="flex-shrink-0">{category}</span>
              <span class="block h-px flex-1 bg-[#d4ccc4] dark:bg-[#2a2a2a]"></span>
            </h2>
            <div class="space-y-3">
              {faqs.map(({ question, answer }) => (
                <details class="group rounded-2xl border border-[#d4ccc4] dark:border-[#2a2a2a] overflow-hidden transition-colors duration-200 bg-white dark:bg-[#1a1a1a]">
                  <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
                    <h3 class="text-base font-semibold pr-4 text-[#1c1714] dark:text-white">{question}</h3>
                    <div class="flex-shrink-0 flex h-8 w-8 items-center justify-center rounded-full transition-all duration-200 bg-[#edeae5] dark:bg-[#2a2a2a]">
                      <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24"
                        stroke="#c8920a" stroke-width="2.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                      </svg>
                    </div>
                  </summary>
                  <div class="px-6 pb-6">
                    <p class="leading-relaxed text-sm text-[#6b6560] dark:text-[#9ca3af]">{answer}</p>
                  </div>
                </details>
              ))}
            </div>
          </div>
        </AnimatedSection>
      ))}

      <!-- Still have questions -->
      <AnimatedSection animation="fadeUp" client:load>
        <div class="rounded-3xl p-8 text-center" style="background:#c8920a">
          <h2 class="text-2xl font-bold mb-3 text-white">Still have a question?</h2>
          <p class="mb-6 text-sm" style="color:rgba(255,255,255,0.8)">Can't find what you're looking for? Reach out and we'll get back to you quickly.</p>
          <a
            href="mailto:hello@nomsai.app"
            class="inline-flex items-center gap-2 rounded-xl px-6 py-3 font-semibold transition-all duration-200 hover:opacity-90 active:scale-95"
            style="background:white;color:#c8920a"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            hello@nomsai.app
          </a>
        </div>
      </AnimatedSection>

    </div>
  </section>

  <AppStoreBadges variant="section" />

</Layout>
