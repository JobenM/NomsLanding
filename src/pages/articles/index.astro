---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AnimatedSection from '../../components/AnimatedSection.tsx';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title="Articles — NomsAI: AI Calorie Tracking & Nutrition Insights"
  description="Practical articles about AI calorie tracking, macro counting, nutrition science, and building sustainable food tracking habits. No login required to read."
>

  <!-- Page Hero -->
  <section class="py-20 sm:py-28 border-b bg-white dark:bg-[#0a0a0a]" style="border-color:#d4ccc4">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <AnimatedSection animation="fadeUp" client:load>
        <p class="text-sm font-bold uppercase tracking-widest mb-4" style="color:#c8920a">Articles</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-6" style="color:#1c1714">
          Nutrition insights &amp; tips
        </h1>
        <p class="text-xl leading-relaxed max-w-2xl mx-auto" style="color:#6b6560">
          Practical guides on AI calorie tracking, macro counting, and building nutrition habits that actually stick.
        </p>
      </AnimatedSection>
    </div>
  </section>

  <!-- Article listing -->
  <section class="py-20 sm:py-28 bg-[#f4f2ef] dark:bg-[#0a0a0a]">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">

      {posts.length === 0 ? (
        <AnimatedSection animation="fadeUp" client:load>
          <div class="text-center py-20">
            <div class="flex h-20 w-20 items-center justify-center rounded-3xl mx-auto mb-6" style="background:#edeae5">
              <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="#6b6560" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6V7.5z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold mb-2" style="color:#1c1714">Articles coming soon</h2>
            <p style="color:#6b6560">We're writing guides on AI calorie tracking and nutrition. Check back soon.</p>
          </div>
        </AnimatedSection>
      ) : (
        <AnimatedSection animation="staggerUp" client:load>
          <div class="space-y-8">
            {posts.map((post) => (
              <article class="group rounded-3xl border overflow-hidden transition-all duration-300 hover:shadow-md hover:-translate-y-0.5 bg-white dark:bg-[#1a1a1a]"
                style="border-color:#d4ccc4">
                <a href={`/articles/${post.slug}`} class="block p-8">
                  <div class="flex flex-wrap items-center gap-2 mb-4">
                    <time
                      datetime={post.data.pubDate.toISOString()}
                      class="text-sm"
                      style="color:#6b6560"
                    >
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium"
                        style="background:#edeae5;color:#c8920a">
                        {tag}
                      </span>
                    ))}
                  </div>

                  <h2 class="text-xl sm:text-2xl font-bold mb-3 transition-colors duration-200" style="color:#1c1714">
                    {post.data.title}
                  </h2>

                  <p class="leading-relaxed mb-6" style="color:#6b6560">
                    {post.data.description}
                  </p>

                  <div class="inline-flex items-center gap-2 text-sm font-semibold transition-all duration-200 group-hover:gap-3" style="color:#c8920a">
                    Read article
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </AnimatedSection>
      )}

    </div>
  </section>

</Layout>
